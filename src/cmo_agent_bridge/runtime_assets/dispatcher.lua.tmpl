    )
    result.fired_on_by_unit_guids = collect_identifiers(
        safe_get(contact, { "firedOn", "FiredOn", "firedon" })
    )
    result.firing_at_contact_guids = collect_identifiers(
        safe_get(contact, { "firingAt", "FiringAt", "firingat" })
    )
    return result
end

local function contact_read(arguments)
    local side = resolve_side(arguments)
    local selector = side_api_selector(arguments, side)
    local contact_guid = tostring(arguments.contact_guid)
    local ok, contact = pcall(
        ScenEdit_GetContact,
        { side = selector, guid = contact_guid }
    )
    if not ok or contact == nil then
        error("ScenEdit_GetContact failed: " .. text_or(contact, "contact not found"))
    end
    local observer_side_guid = object_guid(side)
    if observer_side_guid == "" then
        observer_side_guid = selector
    end
    return contact, observer_side_guid
end

local function contact_get_result(arguments)
    local contact, observer_side_guid = contact_read(arguments)
    return Json.object(contact_detail_result(contact, observer_side_guid))
end

local function contact_posture_set_result(arguments)
    local contact, observer_side_guid = contact_read(arguments)
    local requested = tostring(arguments.posture)
    local ok, failure = pcall(function()
        contact.posture = requested
    end)
    if not ok then
        error("contact posture update failed: " .. text_or(failure, "unknown error"))
    end
    local actual, actual_observer_side_guid = contact_read(arguments)
    local observed = text_or(safe_get(actual, { "posture", "Posture" }), "")
    if observed ~= requested then
        error("contact posture did not match readback")
    end
    if actual_observer_side_guid ~= "" then
        observer_side_guid = actual_observer_side_guid
    end
    return Json.object(contact_detail_result(actual, observer_side_guid))
end

local function contact_weapon_allocations_get_result(arguments)
    local side_guid = tostring(arguments.side_guid)
    local contact_guid = tostring(arguments.contact_guid)
    local ok, allocations = pcall(
        ScenEdit_WeaponAllocation,
        nil,
        contact_guid,
        side_guid
    )
    if not ok or allocations == nil then
        error(
            "ScenEdit_WeaponAllocation failed: "
                .. text_or(allocations, "no allocation table returned")
        )
    end
    local results = Json.array()
    for _, allocation in ipairs(collect_ordered(allocations)) do
        results[#results + 1] = Json.object({
            shooter_guid = text_or(
                safe_get(allocation, { "shooter", "Shooter" }),
                ""
            ),
            quantity_assigned = integer_or(
                safe_get(allocation, { "qtyAssigned", "QtyAssigned", "qtyassigned" }),
                0
            ),
            weapon_dbid = integer_or(
                safe_get(allocation, { "weapon", "Weapon", "weapon_dbid" }),
                0
            ),
            weapon_name = text_or(
                safe_get(allocation, { "weaponName", "WeaponName", "weapon_name" }),
                ""
            ),
            target_guid = text_or(
                safe_get(allocation, { "target", "Target" }),
                contact_guid
            ),
            quantity_fired = integer_or(
                safe_get(allocation, { "qtyFired", "QtyFired", "qtyfired" }),
                0
            ),
        })
    end
    return Json.object({
        contact_guid = contact_guid,
        allocations = results,
    })
end

local function contact_list_result(arguments)
    local side = resolve_side(arguments)
    local selector = side_api_selector(arguments, side)
    local ok, wrappers = pcall(ScenEdit_GetContacts, selector)
    if not ok or wrappers == nil then
        error("ScenEdit_GetContacts failed: " .. text_or(wrappers, "no contacts returned"))
    end
    local observer_side_guid = object_guid(side)
    if observer_side_guid == "" then
        observer_side_guid = selector
    end
    local normalized = {}
    for _, contact in ipairs(collect(wrappers)) do
        local result = contact_full_result(contact, observer_side_guid)
        if arguments.contact_type == nil
            or arguments.contact_type == Json.null
            or lower_text(result.type) == lower_text(arguments.contact_type)
        then
            normalized[#normalized + 1] = result
        end
    end
    return page_and_project(normalized, arguments, CONTACT_FIELDS, "contact.list")
end

