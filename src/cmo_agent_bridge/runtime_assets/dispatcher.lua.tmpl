local function mission_air_refueling_update_result(arguments)
    local side = resolve_side(arguments)
    local side_selector = side_api_selector(arguments, side)
    local mission_guid = tostring(arguments.mission_guid)
    local current, _ = mission_readback(side, side_selector, mission_guid)
    local mission_class = mission_class_values(current)
    local descriptor = {}
    local direct_mapping = {
        use_refuel_unrep = "use_refuel_unrep",
        launch_without_tankers_in_place = "launchMissionWithoutTankersInPlace",
        tanker_follows_receivers = "TankerFollowsReceivers",
        keep_on_mission_without_tankers_in_place = (
            "KeepOnMissionWithoutTankersInPlace"
        ),
        minimum_tankers_total = "tankerMinNumber_total",
        minimum_tankers_airborne = "tankerMinNumber_airborne",
        minimum_tankers_on_station = "tankerMinNumber_station",
        max_receivers_in_queue_per_tanker = (
            "maxReceiversInQueuePerTanker_airborne"
        ),
        fuel_percent_to_start_looking = (
            "fuelQtyToStartLookingForTanker_airborne"
        ),
        tanker_max_distance_nm = "tankerMaxDistance_airborne",
    }
    for public_name, cmo_name in pairs(direct_mapping) do
        local value = arguments[public_name]
        if value ~= nil and value ~= Json.null then
            descriptor[cmo_name] = value
        end
    end
    if arguments.tanker_usage ~= nil and arguments.tanker_usage ~= Json.null then
        descriptor.tankerUsage = arguments.tanker_usage == "automatic"
            and "Automatic"
            or "Mission"
    end
    if arguments.tanker_mission_guids ~= nil
        and arguments.tanker_mission_guids ~= Json.null
    then
        descriptor.tankerMissionList = ordered_strings(
            arguments.tanker_mission_guids
        )
    end
    if arguments.tanker_one_time ~= nil and arguments.tanker_one_time ~= Json.null then
        if mission_class ~= "support" then
            error("tanker_one_time requires a support mission")
        end
        descriptor.TankerOneTime = arguments.tanker_one_time == true
    end
    if arguments.tanker_max_receivers ~= nil
        and arguments.tanker_max_receivers ~= Json.null
    then
        if mission_class ~= "support" then
            error("tanker_max_receivers requires a support mission")
        end
        descriptor.TankerMaxReceivers = arguments.tanker_max_receivers
    end

    local ok, updated = pcall(
        ScenEdit_SetMission,
        side_selector,
        mission_guid,
        descriptor
    )
    if not ok or updated == nil or updated == false then
        error(
            "ScenEdit_SetMission failed for air refueling: "
                .. text_or(updated, "no mission returned")
        )
    end
    local _, actual = mission_readback(side, side_selector, mission_guid)
    local settings = actual.air_refueling
    if settings == nil or settings == Json.null then
        error("air-refueling settings could not be read back")
    end
    local scalar_checks = {
        { argument = "use_refuel_unrep", actual = settings.use_refuel_unrep },
        { argument = "tanker_usage", actual = settings.tanker_usage },
        {
            argument = "launch_without_tankers_in_place",
            actual = settings.launch_without_tankers_in_place,
        },
        {
            argument = "tanker_follows_receivers",
            actual = settings.tanker_follows_receivers,
        },
        {
            argument = "keep_on_mission_without_tankers_in_place",
            actual = settings.keep_on_mission_without_tankers_in_place,
        },
        { argument = "minimum_tankers_total", actual = settings.minimum_tankers_total },
        {
            argument = "minimum_tankers_airborne",
            actual = settings.minimum_tankers_airborne,
        },
        {
            argument = "minimum_tankers_on_station",
            actual = settings.minimum_tankers_on_station,
        },
        {
            argument = "max_receivers_in_queue_per_tanker",
            actual = settings.max_receivers_in_queue_per_tanker,
        },
        {
            argument = "fuel_percent_to_start_looking",
            actual = settings.fuel_percent_to_start_looking,
        },
        {
            argument = "tanker_max_distance_nm",
            actual = settings.tanker_max_distance_nm,
        },
        { argument = "tanker_one_time", actual = settings.tanker_one_time },
        {
            argument = "tanker_max_receivers",
            actual = settings.tanker_max_receivers,
        },
    }
    for _, check in ipairs(scalar_checks) do
        local requested = arguments[check.argument]
        if requested ~= nil
            and requested ~= Json.null
            and check.actual ~= requested
        then
            error(check.argument .. " did not match air-refueling readback")
        end
    end
    if arguments.tanker_mission_guids ~= nil
        and arguments.tanker_mission_guids ~= Json.null
        and not same_identifier_sets(
            settings.tanker_mission_guids,
            ordered_strings(arguments.tanker_mission_guids)
        )
    then
        error("tanker mission list did not match air-refueling readback")
    end
    return Json.object({
        mission_guid = actual.guid,
        mission_name = actual.name,
        use_refuel_unrep = settings.use_refuel_unrep,
        tanker_usage = settings.tanker_usage,
        launch_without_tankers_in_place = (
            settings.launch_without_tankers_in_place
        ),
        tanker_follows_receivers = settings.tanker_follows_receivers,
        keep_on_mission_without_tankers_in_place = (
            settings.keep_on_mission_without_tankers_in_place
        ),
        tanker_mission_guids = settings.tanker_mission_guids,
        minimum_tankers_total = settings.minimum_tankers_total,
        minimum_tankers_airborne = settings.minimum_tankers_airborne,
        minimum_tankers_on_station = settings.minimum_tankers_on_station,
        max_receivers_in_queue_per_tanker = (
            settings.max_receivers_in_queue_per_tanker
        ),
        fuel_percent_to_start_looking = settings.fuel_percent_to_start_looking,
        tanker_max_distance_nm = settings.tanker_max_distance_nm,
        tanker_one_time = settings.tanker_one_time,
        tanker_max_receivers = settings.tanker_max_receivers,
    })
end

local function mission_flight_plan_waypoint_result(waypoint, index)
    local latitude = nullable_number(
        safe_get(waypoint, { "latitude", "Latitude", "lat", "Lat" })
    )
    local longitude = nullable_number(
        safe_get(waypoint, { "longitude", "Longitude", "lon", "Lon" })
    )
    if latitude == Json.null or longitude == Json.null then
        error("flight-plan waypoint coordinates could not be read back")
    end
    local action = safe_get(
        waypoint,
        {
            "Action",
            "action",
            "SpecialAction",
            "specialAction",
            "ActionGUID",
            "actionGuid",
        }
    )
    local action_guid = normalized_object_reference(action)
    return {
        index = index,
        guid = nullable_text(safe_get(waypoint, { "GUID", "guid", "Guid" })),
        name = text_or(safe_get(waypoint, { "Name", "name" }), ""),
        description = nullable_text(
            safe_get(waypoint, { "Description", "description" })
        ),
        waypoint_type = nullable_scalar(
            safe_get(waypoint, { "TypeOf", "typeof", "Type", "type" })
        ),
        latitude = latitude,
        longitude = longitude,
        scheduled_time = nullable_text(
            safe_get(
                waypoint,
                { "Zulu", "zulu", "ScheduledTime", "scheduledTime", "Time", "time" }
            )
        ),
        desired_speed = nullable_number(
            safe_get(waypoint, { "DesiredSpeed", "desiredSpeed", "desiredspeed" })
        ),
        desired_altitude_m = nullable_number(
            safe_get(
                waypoint,
                { "DesiredAltitude", "desiredAltitude", "desiredaltitude" }
            )
        ),
        terrain_following = nullable_boolean(
            safe_get(
                waypoint,
                { "DesiredAltitudeTF", "desiredAltitudeTF", "desiredaltitudetf" }
            )
        ),
        preset_throttle = nullable_scalar(
            safe_get(
                waypoint,
                { "PresetThrottle", "presetThrottle", "presetthrottle" }
            )
        ),
        preset_altitude = nullable_scalar(
            safe_get(
                waypoint,
                { "PresetAltitude", "presetAltitude", "presetaltitude" }
            )
        ),
        preset_depth = nullable_scalar(
            safe_get(waypoint, { "PresetDepth", "presetDepth", "presetdepth" })
        ),
        action_guid = action_guid,
    }
end

local function mission_flight_plan_result(flight)
    local guid = object_guid(flight)
    if guid == "" then
        error("flight-plan GUID could not be read back")
    end
    local waypoints = Json.array()
    local course = safe_get(
        flight,
        { "course", "Course", "waypoints", "Waypoints", "flightcourse", "FlightCourse" }
    )
    for index, waypoint in ipairs(collect_ordered(course)) do
        waypoints[#waypoints + 1] = Json.object(
            mission_flight_plan_waypoint_result(waypoint, index)
        )
    end
    return {
        guid = guid,
        name = text_or(
            safe_get(flight, { "Name", "name", "Callsign", "callsign" }),
            ""
        ),
        waypoints = waypoints,
    }
end

local function mission_flight_plan_snapshot(mission)
    local flights = Json.array()
    for _, flight in ipairs(
        collect_ordered(
            safe_get(
                mission,
                { "flightlist", "FlightList", "flightList", "flights", "Flights" }
            )
        )
    ) do
        flights[#flights + 1] = Json.object(mission_flight_plan_result(flight))
    end
    return {
        mission_guid = object_guid(mission),
        mission_name = object_name(mission),
        takeoff_time = nullable_text(
            safe_get(
                mission,
                { "TakeOffTime", "takeOffTime", "takeofftime", "TakeoffTime" }
            )
        ),
        time_on_target = nullable_text(
            safe_get(
                mission,
                {
                    "TimeOnTargetStation",
                    "timeOnTargetStation",
                    "timeontargetstation",
                    "TimeOnTarget",
                }
            )
        ),
        flights = flights,
    }
end

local function mission_flight_plan_list_result(arguments)
    local side = resolve_side(arguments)
    local side_selector = side_api_selector(arguments, side)
    local mission, _ = mission_readback(
        side,
        side_selector,
        tostring(arguments.mission_guid)
    )
    return Json.object(mission_flight_plan_snapshot(mission))
end

local function mission_flight_plan_create_result(arguments)
    local side = resolve_side(arguments)
    local side_selector = side_api_selector(arguments, side)
    local mission_guid = tostring(arguments.mission_guid)
    local before_mission, _ = mission_readback(side, side_selector, mission_guid)
    local before = mission_flight_plan_snapshot(before_mission)
    local before_guids = {}
    for _, flight in ipairs(before.flights) do
        before_guids[lower_text(flight.guid)] = true
    end

    local options = {}
    if arguments.date_on_target ~= nil and arguments.date_on_target ~= Json.null then
        options.DATEONTARGET = tostring(arguments.date_on_target)
        options.TIMEONTARGET = tostring(arguments.time_on_target)
    else
        options.TAKEOFFDATE = tostring(arguments.takeoff_date)
        options.TAKEOFFTIME = tostring(arguments.takeoff_time)
    end
    local ok, created = pcall(
        ScenEdit_CreateMissionFlightPlan,
        side_selector,
        mission_guid,
        options
    )
    if not ok or created == nil or created == false then
        error(
            "ScenEdit_CreateMissionFlightPlan failed: "
                .. text_or(created, "no flight returned")
        )
    end

    local after_mission, _ = mission_readback(side, side_selector, mission_guid)
    local actual = mission_flight_plan_snapshot(after_mission)
    local created_flight_guids = Json.array()
    for _, flight in ipairs(actual.flights) do
        if not before_guids[lower_text(flight.guid)] then
            created_flight_guids[#created_flight_guids + 1] = flight.guid
        end
    end
    if #created_flight_guids == 0 then
        error("created flight plan was not present in mission readback")
    end
    return Json.object({
        mission_guid = actual.mission_guid,
        mission_name = actual.mission_name,
        takeoff_time = actual.takeoff_time,
        time_on_target = actual.time_on_target,
        flights = actual.flights,
        created_flight_guids = created_flight_guids,
    })
end

local function mission_delete_result(arguments)
    require_confirmation_proof(arguments)
    local side = resolve_side(arguments)
    local side_selector = side_api_selector(arguments, side)
    local mission_guid = tostring(arguments.mission_guid)
    local read_ok, mission = pcall(ScenEdit_GetMission, side_selector, mission_guid)
    if not read_ok or mission == nil then
        error("mission to delete was not found")
    end
    local deleted_name = object_name(mission)

    local delete_ok, deleted = pcall(
        ScenEdit_DeleteMission,
        side_selector,
        mission_guid
    )
    if not delete_ok or deleted == nil or deleted == false then
        error("ScenEdit_DeleteMission failed: " .. text_or(deleted, "false"))
    end

    local verify_ok, remaining = pcall(
        ScenEdit_GetMission,
        side_selector,
        mission_guid
    )
    if verify_ok and remaining ~= nil then
        error("mission remained present after deletion")
    end
    return Json.object({
        deleted_guid = mission_guid,
        deleted_name = deleted_name,
        object_kind = "mission",
    })
end

local function mission_target_result(arguments, assign)
    local side = resolve_side(arguments)
    local side_selector = side_api_selector(arguments, side)
    local mission_guid = tostring(arguments.mission_guid)
    local target_guid = tostring(arguments.target_guid)
    local _, before = mission_readback(side, side_selector, mission_guid)
    if before.mission_class ~= "strike" then
        error("mission targets can only be changed on a strike mission")
    end
    local api = assign and ScenEdit_AssignUnitAsTarget or ScenEdit_RemoveUnitAsTarget
    local ok, changed = pcall(api, target_guid, mission_guid)
    if not ok or changed == nil or changed == false then
        error("mission target update failed: " .. text_or(changed, "no targets returned"))
    end
    local _, actual = mission_readback(side, side_selector, mission_guid)
    local observed = contains_identifier(actual.target_guids, target_guid)
    if observed ~= assign then
        error("mission target state did not match readback")
    end
    return Json.object({
        mission_guid = actual.guid,
        target_guid = target_guid,
        assigned = observed,
        target_guids = actual.target_guids,
    })
end

local function mission_cargo_update_result(arguments)
    local side = resolve_side(arguments)
    local side_selector = side_api_selector(arguments, side)
    local mission_guid = tostring(arguments.mission_guid)
    local mission, before = mission_readback(side, side_selector, mission_guid)
    if before.mission_class ~= "cargo" then
        error("mission cargo can only be changed on a cargo mission")
    end

    local action = tostring(arguments.action)
    local cargo_kind = tostring(arguments.cargo_kind)
    local method_name
    local call_arguments
    if cargo_kind == "mount" then
        method_name = action == "assign"
            and "addAssignedCargoMount"
            or "removeAssignedCargoMount"
        call_arguments = {
            integer_or(arguments.dbid, 0),
            integer_or(arguments.quantity, 0),
        }
    else
        method_name = action == "assign"
            and "addAssignedCargo"
            or "removeAssignedCargo"
        call_arguments = {
            integer_or(arguments.object_type, 0),
            integer_or(arguments.dbid, 0),
            tostring(arguments.cargo_guid),
        }
    end
    local method = safe_get(mission, { method_name })
    if method == nil then
        error("cargo mission wrapper does not expose " .. method_name)
    end
    local ok, changed = pcall(
        method,
        mission,
        call_arguments[1],
        call_arguments[2],
        call_arguments[3]
    )
    if not ok or changed == false then
        error(method_name .. " failed: " .. text_or(changed, "false"))
    end
    local _, actual = mission_readback(side, side_selector, mission_guid)
    return Json.object({
        mission_guid = actual.guid,
        action = action,
        assigned_cargo = actual.assigned_cargo,
    })
end

local function doctrine_selector(arguments, actual)
    local selector = { actual = actual == true }
    if arguments.scope == "side" then
        selector.side = tostring(arguments.side_guid or arguments.target_guid)
    elseif arguments.scope == "unit" or arguments.scope == "group" then
        selector.guid = tostring(arguments.unit_guid or arguments.target_guid)
        if arguments.side_guid ~= nil and arguments.side_guid ~= Json.null then
            selector.side = tostring(arguments.side_guid)
        end
    elseif arguments.scope == "mission" then
        selector.mission = tostring(arguments.mission_guid or arguments.target_guid)
        if arguments.side_guid ~= nil and arguments.side_guid ~= Json.null then
            selector.side = tostring(arguments.side_guid)
        end
    else
        error("unsupported doctrine scope")
    end
    return selector
end

local function normalized_wcs(value)
    if value == nil or value == Json.null then
        return Json.null
    end
    local numeric = tonumber(value)
    if numeric == 0 then return "Free" end
    if numeric == 1 then return "Tight" end
    if numeric == 2 then return "Hold" end
    local key = string.lower(string.gsub(tostring(value), "[^%w]", ""))
    if string.find(key, "free", 1, true) ~= nil then return "Free" end
    if string.find(key, "tight", 1, true) ~= nil then return "Tight" end
    if string.find(key, "hold", 1, true) ~= nil then return "Hold" end
    return Json.null
end

local function normalized_refuel_unrep(value)
    if value == nil or value == Json.null then
        return Json.null
    end
    local numeric = tonumber(value)
    if numeric == 0 then return "Always_ExceptTankersRefuellingTankers" end
    if numeric == 1 then return "Never" end
    if numeric == 2 then return "Always_IncludingTankersRefuellingTankers" end
    local key = string.lower(string.gsub(tostring(value), "[^%w]", ""))
    if string.find(key, "including", 1, true) ~= nil then
        return "Always_IncludingTankersRefuellingTankers"
    end
    if string.find(key, "except", 1, true) ~= nil then
        return "Always_ExceptTankersRefuellingTankers"
    end
    if string.find(key, "never", 1, true) ~= nil then
        return "Never"
    end
    return Json.null
end

local function normalized_emcon(value)
    if value == nil or value == Json.null then
        return Json.null
    end
    if type(value) == "boolean" then
        return value and "Active" or "Passive"
    end
    local numeric = tonumber(value)
    if numeric == 1 then return "Active" end
    if numeric == 0 then return "Passive" end
    local key = string.lower(string.gsub(tostring(value), "[^%w]", ""))
    if string.find(key, "active", 1, true) ~= nil
        and string.find(key, "passive", 1, true) == nil
    then
        return "Active"
    end
    if string.find(key, "passive", 1, true) ~= nil then
        return "Passive"
    end
    return Json.null
end

