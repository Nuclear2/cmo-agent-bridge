local function normalized_mission_refuel_unrep(value)
    if value == nil or value == Json.null then
        return Json.null
    end
    local numeric = tonumber(value)
    if numeric == 0 then return "Always_ExceptTankersRefuellingTankers" end
    if numeric == 1 then return "Never" end
    if numeric == 2 then return "Always_IncludingTankersRefuellingTankers" end
    local key = string.lower(string.gsub(tostring(value), "[^%w]", ""))
    if string.find(key, "including", 1, true) ~= nil then
        return "Always_IncludingTankersRefuellingTankers"
    elseif string.find(key, "except", 1, true) ~= nil then
        return "Always_ExceptTankersRefuellingTankers"
    elseif string.find(key, "never", 1, true) ~= nil then
        return "Never"
    end
    return Json.null
end

local function normalized_tanker_usage(value)
    if value == nil or value == Json.null then
        return Json.null
    end
    local numeric = tonumber(value)
    if numeric == 0 then
        return "automatic"
    elseif numeric == 1 then
        return "mission"
    end
    local key = string.lower(string.gsub(tostring(value), "[^%w]", ""))
    if string.find(key, "automatic", 1, true) ~= nil
        or string.find(key, "auto", 1, true) ~= nil
    then
        return "automatic"
    elseif string.find(key, "mission", 1, true) ~= nil then
        return "mission"
    end
    return Json.null
end

