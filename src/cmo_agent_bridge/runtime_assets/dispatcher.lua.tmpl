local function authoring_json_value(value, depth, seen)
    if value == nil or value == Json.null then
        return Json.null
    end
    local kind = type(value)
    if kind == "boolean" or kind == "string" then
        return value
    elseif kind == "number" then
        if value ~= value or value == math.huge or value == -math.huge then
            return Json.null
        end
        return value
    end
    if depth >= 10 then
        return text_or(value, "")
    end
    if kind == "table" then
        if seen[value] then
            return Json.null
        end
        seen[value] = true
        local numeric = {}
        local named = {}
        local numeric_only = true
        local ok = pcall(function()
            for key, item in pairs(value) do
                local numeric_key = tonumber(key)
                if numeric_key ~= nil and numeric_key == math.floor(numeric_key) then
                    numeric[#numeric + 1] = {
                        order = numeric_key,
                        value = authoring_json_value(item, depth + 1, seen),
                    }
                else
                    numeric_only = false
                    named[tostring(key)] = authoring_json_value(item, depth + 1, seen)
                end
            end
        end)
        if not ok then
            seen[value] = nil
            return text_or(value, "")
        end
        table.sort(numeric, function(left, right) return left.order < right.order end)
        if numeric_only then
            local result = Json.array()
            for _, entry in ipairs(numeric) do
                result[#result + 1] = entry.value
            end
            seen[value] = nil
            return result
        end
        if #numeric > 0 then
            local items = Json.array()
            for _, entry in ipairs(numeric) do
                items[#items + 1] = entry.value
            end
            named._items = items
        end
        seen[value] = nil
        return Json.object(named)
    end

    local projected = Json.object()
    local populated = false
    for _, field in ipairs(AUTHORING_WRAPPER_FIELDS) do
        local item = safe_get(value, { field })
        if item ~= nil then
            projected[field] = authoring_json_value(item, depth + 1, seen)
            populated = true
        end
    end
    if populated then
        return projected
    end
    return text_or(value, "")
end

local function authoring_data_result(operation, accepted, value)
    return Json.object({
        operation = operation,
        accepted = accepted == true,
        data = authoring_json_value(value, 0, {}),
    })
end

local function scenario_weather_result()
    local ok, weather = pcall(ScenEdit_GetWeather)
    if not ok or weather == nil then
        error("ScenEdit_GetWeather failed: " .. text_or(weather, "no weather returned"))
    end
    return Json.object({
        temperature_c = number_or(
            safe_get(weather, { "temp", "Temp", "temperature", "Temperature" }),
            0
        ),
        rainfall = number_or(safe_get(weather, { "rainfall", "Rainfall" }), 0),
        undercloud_fraction = number_or(
            safe_get(weather, { "undercloud", "Undercloud" }),
            0
        ),
        sea_state = integer_or(
            safe_get(weather, { "seastate", "SeaState", "sea_state" }),
            0
        ),
    })
end

local function parse_scenario_datetime(value, field_name)
    local year, month, day, hour, minute, second = string.match(
        tostring(value),
        "^(%d%d%d%d)%-(%d%d)%-(%d%d)T(%d%d):(%d%d):(%d%d)$"
    )
    if year == nil then
        error(field_name .. " must use YYYY-MM-DDTHH:MM:SS")
    end
    return year .. "." .. month .. "." .. day, hour .. ":" .. minute .. ":" .. second
end

local function scenario_readback_result()
    local scenario, lineage_id = scenario_context()
    return scenario_result(scenario, lineage_id)
end

local function normalize_script_newlines(script)
    local normalized = string.gsub(tostring(script or ""), "\r\n", "\n")
    normalized = string.gsub(normalized, "\r", "\n")
    return string.gsub(normalized, "\n", "\r\n")
end

local BRIDGE_POLL_SCRIPT_PATH = "CMOAgentBridge/inbox/request.lua"
local managed_bridge_selectors_cache = nil

local function record_managed_selector(selectors, value)
    local normalized = lower_text(value)
    if normalized ~= "" then
        selectors[normalized] = true
    end
end

local function record_managed_wrapper(selectors, wrapper)
    record_managed_selector(selectors, object_guid(wrapper))
    record_managed_selector(selectors, object_name(wrapper))
    record_managed_selector(
        selectors,
        safe_get(wrapper, { "description", "Description" })
    )
end

local function action_script_text(action)
    local script = text_or(
        safe_get(action, { "ScriptText", "scriptText", "scripttext" }),
        ""
    )
    if string.find(script, BRIDGE_POLL_SCRIPT_PATH, 1, true) ~= nil then
        return script
    end
    local selector = text_or(
        safe_get(
            action,
            { "guid", "Guid", "GUID", "description", "Description", "name", "Name" }
        ),
        ""
    )
    if selector == "" then
        selector = text_or(action, "")
    end
    if selector == "" then
        return script
    end
    local ok, listed = pcall(
        ScenEdit_SetAction,
        { mode = "list", description = selector }
    )
    if not ok or listed == nil then
        return script
    end
    return text_or(
        safe_get(listed, { "ScriptText", "scriptText", "scripttext" }),
        script
    )
end

local function managed_bridge_selectors()
    if managed_bridge_selectors_cache ~= nil then
        return managed_bridge_selectors_cache
    end
    local selectors = {}
    local ok, events = pcall(ScenEdit_GetEvents, 0)
    if ok and events ~= nil then
        for _, event in ipairs(collect(events)) do
            local actions = collect(safe_get(event, { "actions", "Actions" }))
            local is_bridge_event = false
            for _, action in ipairs(actions) do
                if string.find(
                    action_script_text(action),
                    BRIDGE_POLL_SCRIPT_PATH,
                    1,
                    true
                ) ~= nil then
                    is_bridge_event = true
                    break
                end
            end
            if is_bridge_event then
                record_managed_wrapper(selectors, event)
                for _, key in ipairs({
                    { "triggers", "Triggers" },
                    { "conditions", "Conditions" },
                    { "actions", "Actions" },
                }) do
                    for _, component in ipairs(collect(safe_get(event, key))) do
                        record_managed_wrapper(selectors, component)
                        record_managed_selector(selectors, component)
                    end
                end
            end
        end
    end
    local actions_ok, special_actions = pcall(
        ScenEdit_GetSpecialAction,
        { mode = "list" }
    )
    if actions_ok and special_actions ~= nil then
        for _, action in ipairs(collect(special_actions)) do
            local script = text_or(
                safe_get(action, { "ScriptText", "scriptText", "scripttext" }),
                ""
            )
            if string.find(script, BRIDGE_POLL_SCRIPT_PATH, 1, true) ~= nil then
                record_managed_wrapper(selectors, action)
            end
        end
    end
    managed_bridge_selectors_cache = selectors
    return selectors
end

local function is_managed_bridge_object(selector)
    local key = lower_text(selector)
    return string.find(key, "cmoagentbridge", 1, true) ~= nil
        or string.find(key, "cmo agent bridge", 1, true) ~= nil
        or managed_bridge_selectors()[key] == true
end

local function lua_call_result(arguments)
    local function_name = tostring(arguments["function"])
    local call_arguments = arguments.arguments or {}

    if function_name == "ScenEdit_GetScore" then
        local side = call_arguments.side
        local ok, score = pcall(ScenEdit_GetScore, side)
        if not ok then
            error("ScenEdit_GetScore failed: " .. text_or(score, "unknown error"))
        end
        return Json.object({ side = tostring(side), score = integer_or(score, 0) })
    elseif function_name == "ScenEdit_GetWeather" then
        return scenario_weather_result()
    elseif function_name == "ScenEdit_SetWeather" then
        local ok, changed = pcall(
            ScenEdit_SetWeather,
            number_or(call_arguments.temperature_c, 0),
            number_or(call_arguments.rainfall, 0),
            number_or(call_arguments.undercloud_fraction, 0),
            integer_or(call_arguments.sea_state, 0)
        )
        if not ok or changed == false then
            error("ScenEdit_SetWeather failed: " .. text_or(changed, "false"))
        end
        return scenario_weather_result()
    elseif function_name == "SetScenarioTitle" then
        local ok, changed = pcall(SetScenarioTitle, tostring(call_arguments.title))
        if not ok or changed == false then
            error("SetScenarioTitle failed: " .. text_or(changed, "false"))
        end
        return scenario_readback_result()
    elseif function_name == "ScenEdit_SetTime" then
        local descriptor = { DateFormat = "YYYYMMDD" }
        if call_arguments.current_time ~= nil
            and call_arguments.current_time ~= Json.null
        then
            descriptor.Date, descriptor.Time = parse_scenario_datetime(
                call_arguments.current_time,
                "current_time"
            )
        end
        if call_arguments.start_time ~= nil
            and call_arguments.start_time ~= Json.null
        then
            descriptor.StartDate, descriptor.StartTime = parse_scenario_datetime(
                call_arguments.start_time,
                "start_time"
            )
        end
        if call_arguments.duration ~= nil and call_arguments.duration ~= Json.null then
            descriptor.Duration = tostring(call_arguments.duration)
        end
        local ok, changed = pcall(ScenEdit_SetTime, descriptor)
        if not ok or changed == nil or changed == false then
            error("ScenEdit_SetTime failed: " .. text_or(changed, "false"))
        end
        return scenario_readback_result()
    elseif function_name == "ScenEdit_AddSide" then
        local ok, added = pcall(
            ScenEdit_AddSide,
            { side = tostring(call_arguments.name) }
        )
        if not ok or added == nil or added == false then
            error("ScenEdit_AddSide failed: " .. text_or(added, "no side returned"))
        end
        return Json.object(side_full_result(added))
    elseif function_name == "ScenEdit_SetSideOptions" then
        local side = resolve_side({ side_guid = call_arguments.side_guid })
        local selector = side_api_selector({ side_guid = call_arguments.side_guid }, side)
        local descriptor = { side = selector }
        if call_arguments.awareness ~= nil and call_arguments.awareness ~= Json.null then
            descriptor.awareness = call_arguments.awareness
        end
        if call_arguments.proficiency ~= nil and call_arguments.proficiency ~= Json.null then
            descriptor.proficiency = call_arguments.proficiency
        end
        if call_arguments.auto_track_civilians ~= nil
            and call_arguments.auto_track_civilians ~= Json.null
        then
            descriptor.AutoTrackCivillians = call_arguments.auto_track_civilians == true
        end
        if call_arguments.collective_responsibility ~= nil
            and call_arguments.collective_responsibility ~= Json.null
        then
            descriptor.collectiveResponsibility =
                call_arguments.collective_responsibility == true
        end
        if call_arguments.computer_controlled_only ~= nil
            and call_arguments.computer_controlled_only ~= Json.null
        then
            descriptor.computerControlledOnly =
                call_arguments.computer_controlled_only == true
        end
        local ok, changed = pcall(ScenEdit_SetSideOptions, descriptor)
        if not ok or changed == nil or changed == false then
            error("ScenEdit_SetSideOptions failed: " .. text_or(changed, "false"))
        end
        local observed = resolve_side({ side_guid = call_arguments.side_guid })
        return Json.object(side_full_result(observed))
    elseif function_name == "ScenEdit_SetSidePosture" then
        local side_a_guid = tostring(call_arguments.side_a_guid)
        local side_b_guid = tostring(call_arguments.side_b_guid)
        local ok, changed = pcall(
            ScenEdit_SetSidePosture,
            side_a_guid,
            side_b_guid,
            tostring(call_arguments.posture)
        )
        if not ok or changed == false then
            error("ScenEdit_SetSidePosture failed: " .. text_or(changed, "false"))
        end
        local read_ok, posture = pcall(
            ScenEdit_GetSidePosture,
            side_a_guid,
            side_b_guid
        )
        if not read_ok then
            error(
                "ScenEdit_GetSidePosture failed after update: "
                    .. text_or(posture, "unknown error")
            )
        end
        return Json.object({
            side_a_guid = side_a_guid,
            side_b_guid = side_b_guid,
            posture = text_or(posture, tostring(call_arguments.posture)),
        })
    elseif function_name == "ScenEdit_SetScore" then
        local side = tostring(call_arguments.side)
        local ok, score = pcall(
            ScenEdit_SetScore,
            side,
            integer_or(call_arguments.score, 0),
            tostring(call_arguments.reason)
        )
        if not ok or score == nil or score == false then
            error("ScenEdit_SetScore failed: " .. text_or(score, "false"))
        end
        return Json.object({ side = side, score = integer_or(score, 0) })
    elseif function_name == "ScenEdit_GetEvents" then
        local ok, events = pcall(
            ScenEdit_GetEvents,
            integer_or(call_arguments.level, 0)
        )
        if not ok or events == nil then
            error("ScenEdit_GetEvents failed: " .. text_or(events, "no events returned"))
        end
        return authoring_data_result(function_name, true, events)
    elseif function_name == "ScenEdit_GetEvent" then
        local ok, event = pcall(
            ScenEdit_GetEvent,
            tostring(call_arguments.event_id_or_name),
            integer_or(call_arguments.level, 0)
        )
        if not ok or event == nil then
            error("ScenEdit_GetEvent failed: " .. text_or(event, "event not found"))
        end
        return authoring_data_result(function_name, true, event)
    elseif function_name == "ScenEdit_SetEvent" then
        local selector = tostring(call_arguments.event_id_or_name)
        if is_managed_bridge_object(selector)
            or (
                call_arguments.new_description ~= nil
                and call_arguments.new_description ~= Json.null
                and is_managed_bridge_object(call_arguments.new_description)
            )
        then
            error("bridge-managed events cannot be modified")
        end
        local descriptor = { mode = tostring(call_arguments.mode) }
        if call_arguments.new_description ~= nil
            and call_arguments.new_description ~= Json.null
        then
            descriptor.newname = tostring(call_arguments.new_description)
        end
        if call_arguments.active ~= nil and call_arguments.active ~= Json.null then
            descriptor.isActive = call_arguments.active == true
        end
        if call_arguments.shown ~= nil and call_arguments.shown ~= Json.null then
            descriptor.isShown = call_arguments.shown == true
        end
        if call_arguments.repeatable ~= nil and call_arguments.repeatable ~= Json.null then
            descriptor.IsRepeatable = call_arguments.repeatable == true
        end
        if call_arguments.probability ~= nil
            and call_arguments.probability ~= Json.null
        then
            descriptor.Probability = integer_or(call_arguments.probability, 100)
        end
        local ok, event = pcall(ScenEdit_SetEvent, selector, descriptor)
        if not ok or event == nil or event == false then
            error("ScenEdit_SetEvent failed: " .. text_or(event, "false"))
        end
        return authoring_data_result(function_name, true, event)
    elseif function_name == "ScenEdit_SetTrigger"
        or function_name == "ScenEdit_SetCondition"
        or function_name == "ScenEdit_SetAction"
    then
        local selector = tostring(call_arguments.component_id_or_name)
        local mode = tostring(call_arguments.mode)
        if mode ~= "list"
            and (
                is_managed_bridge_object(selector)
                or (
                    call_arguments.new_description ~= nil
                    and call_arguments.new_description ~= Json.null
                    and is_managed_bridge_object(call_arguments.new_description)
                )
            )
        then
            error("bridge-managed event components cannot be modified")
        end
        local descriptor = {}
        local decoded = Json.decode(tostring(call_arguments.parameters_json or "{}"))
        for key, value in pairs(decoded) do
            if value ~= Json.null then
                local normalized_key = lower_text(key)
                local reserved = normalized_key == "mode"
                    or normalized_key == "description"
                    or normalized_key == "name"
                    or normalized_key == "id"
                    or normalized_key == "type"
                    or normalized_key == "newname"
                    or normalized_key == "rename"
                if reserved then
                    -- Trusted envelope fields below are authoritative.
                elseif normalized_key == "scripttext"
                    or normalized_key == "scripttest"
                then
                    descriptor[key] = normalize_script_newlines(value)
                else
                    descriptor[key] = value
                end
            end
        end
        descriptor.mode = mode
        descriptor.description = selector
        if call_arguments.component_type ~= nil
            and call_arguments.component_type ~= Json.null
        then
            descriptor.type = tostring(call_arguments.component_type)
        end
        if call_arguments.new_description ~= nil
            and call_arguments.new_description ~= Json.null
        then
            descriptor.newname = tostring(call_arguments.new_description)
        end
        local api_function = ScenEdit_SetTrigger
        if function_name == "ScenEdit_SetCondition" then
            api_function = ScenEdit_SetCondition
        elseif function_name == "ScenEdit_SetAction" then
            api_function = ScenEdit_SetAction
        end
        local ok, component = pcall(api_function, descriptor)
        if not ok or component == nil or component == false then
            error(function_name .. " failed: " .. text_or(component, "false"))
        end
        return authoring_data_result(function_name, true, component)
    elseif function_name == "ScenEdit_SetEventTrigger"
        or function_name == "ScenEdit_SetEventCondition"
        or function_name == "ScenEdit_SetEventAction"
    then
        local event_selector = tostring(call_arguments.event_id_or_name)
        local component_selector = tostring(call_arguments.component_id_or_name)
        if is_managed_bridge_object(event_selector)
            or is_managed_bridge_object(component_selector)
            or (
                call_arguments.replacement_id_or_name ~= nil
                and call_arguments.replacement_id_or_name ~= Json.null
                and is_managed_bridge_object(call_arguments.replacement_id_or_name)
            )
        then
            error("bridge-managed events and components cannot be modified")
        end
        local descriptor = {
            mode = tostring(call_arguments.mode),
            description = component_selector,
        }
        if call_arguments.replacement_id_or_name ~= nil
            and call_arguments.replacement_id_or_name ~= Json.null
        then
            descriptor.ReplacedBy = tostring(call_arguments.replacement_id_or_name)
        end
        local api_function = ScenEdit_SetEventTrigger
        if function_name == "ScenEdit_SetEventCondition" then
            api_function = ScenEdit_SetEventCondition
        elseif function_name == "ScenEdit_SetEventAction" then
            api_function = ScenEdit_SetEventAction
        end
        local ok, linked = pcall(api_function, event_selector, descriptor)
        if not ok or linked == nil or linked == false then
            error(function_name .. " failed: " .. text_or(linked, "false"))
        end
        return authoring_data_result(function_name, true, linked)
    elseif function_name == "ScenEdit_AddSpecialAction" then
        local side = resolve_side({ side_guid = call_arguments.side_guid })
        local selector = side_api_selector({ side_guid = call_arguments.side_guid }, side)
        local name = tostring(call_arguments.name)
        if is_managed_bridge_object(name) then
            error("bridge-managed special-action names are reserved")
        end
        local descriptor = {
            side = selector,
            ActionNameOrID = name,
            description = tostring(call_arguments.description or ""),
            IsActive = call_arguments.active == true,
            IsRepeatable = call_arguments.repeatable == true,
            ScriptText = normalize_script_newlines(call_arguments.script_text),
        }
        local ok, added = pcall(ScenEdit_AddSpecialAction, descriptor)
        if not ok or added == nil or added == false then
            error("ScenEdit_AddSpecialAction failed: " .. text_or(added, "false"))
        end
        local read_ok, action = pcall(
            ScenEdit_GetSpecialAction,
            { side = selector, ActionNameOrID = name }
        )
        if not read_ok or action == nil then
            error(
                "ScenEdit_GetSpecialAction failed after add: "
                    .. text_or(action, "not found")
            )
        end
        return authoring_data_result(function_name, true, action)
    elseif function_name == "ScenEdit_SetSpecialAction" then
        local side = resolve_side({ side_guid = call_arguments.side_guid })
        local selector = side_api_selector({ side_guid = call_arguments.side_guid }, side)
        local action_selector = tostring(call_arguments.action_id_or_name)
        if is_managed_bridge_object(action_selector)
            or (
                call_arguments.new_name ~= nil
                and call_arguments.new_name ~= Json.null
                and is_managed_bridge_object(call_arguments.new_name)
            )
        then
            error("bridge-managed special actions cannot be modified")
        end
        local descriptor = {
            side = selector,
            ActionNameOrID = action_selector,
        }
        if tostring(call_arguments.mode) == "remove" then
            descriptor.mode = "remove"
        end
        if call_arguments.new_name ~= nil and call_arguments.new_name ~= Json.null then
            descriptor.newname = tostring(call_arguments.new_name)
        end
        if call_arguments.description ~= nil
            and call_arguments.description ~= Json.null
        then
            descriptor.description = tostring(call_arguments.description)
        end
        if call_arguments.active ~= nil and call_arguments.active ~= Json.null then
            descriptor.isActive = call_arguments.active == true
        end
        if call_arguments.repeatable ~= nil and call_arguments.repeatable ~= Json.null then
            descriptor.IsRepeatable = call_arguments.repeatable == true
        end
        if call_arguments.script_text ~= nil
            and call_arguments.script_text ~= Json.null
        then
            descriptor.ScriptText = normalize_script_newlines(call_arguments.script_text)
        end
        local ok, changed = pcall(ScenEdit_SetSpecialAction, descriptor)
        if not ok or changed == nil or changed == false then
            error("ScenEdit_SetSpecialAction failed: " .. text_or(changed, "false"))
        end
        if descriptor.mode == "remove" then
            return authoring_data_result(function_name, true, {
                side = selector,
                ActionNameOrID = action_selector,
                removed = true,
            })
        end
        local read_selector = descriptor.newname or action_selector
        local read_ok, action = pcall(
            ScenEdit_GetSpecialAction,
            { side = selector, ActionNameOrID = read_selector }
        )
        if not read_ok or action == nil then
            error(
                "ScenEdit_GetSpecialAction failed after update: "
                    .. text_or(action, "not found")
            )
        end
        return authoring_data_result(function_name, true, action)
    end

    error("lua.call function is not enabled")
end

local function response_error(code, message, details)
    return Json.object({
        code = code,
        message = message,
        details = details or Json.object(),
    })
end

local function export_anchor()
    local ok, wrappers = pcall(VP_GetSides)
    if not ok or wrappers == nil then
        return nil, nil
    end
    local first_side = nil
    for _, side in ipairs(collect(wrappers)) do
        local side_selector = text_or(
            safe_get(side, { "guid", "Guid", "GUID", "name", "Name" }),
            ""
        )
        if side_selector ~= "" and first_side == nil then
            first_side = side_selector
        end
        for _, unit in ipairs(collect(safe_get(side, { "units", "Units" }))) do
            local unit_guid = text_or(safe_get(unit, { "guid", "Guid", "GUID" }), "")
            if side_selector ~= "" and unit_guid ~= "" then
                return side_selector, unit_guid
            end
        end
    end
    return first_side, nil
end

local function write_response(request_id, envelope_json)
    local side_selector, unit_guid = export_anchor()
    if side_selector == nil then
        print("CMO_AGENT_BRIDGE|EXPORT_FAILED|no side is available for ScenEdit_ExportInst")
        return false
    end
    local units = {}
    if unit_guid ~= nil then
        units[1] = unit_guid
    end
    local ok, result = pcall(
        ScenEdit_ExportInst,
        side_selector,
        units,
        {
            filename = "CMOAgentBridge_Response_" .. request_id .. ".inst",
            name = "CMO Agent Bridge Response",
            comment = envelope_json,
        }
    )
    if not ok then
        print("CMO_AGENT_BRIDGE|EXPORT_FAILED|" .. text_or(result, "unknown error"))
        return false
    end
    local exported_count = tonumber(result)
    if exported_count == nil or exported_count < 1 then
        print("CMO_AGENT_BRIDGE|EXPORT_FAILED|no unit was exported")
        return false
    end
    return true
end

local function envelope(delivery, lineage_id, activation_id, scenario_time, result, failure)
    return Json.object({
        protocol = BRIDGE.protocol,
        request_id = delivery.request_id,
        delivery_id = delivery.delivery_id,
        request_hash = delivery.request_hash,
        ok = failure == nil,
        result = failure == nil and result or Json.null,
        error = failure == nil and Json.null or failure,
        scenario_time = scenario_time,
        scenario_lineage_id = lineage_id,
        activation_id = activation_id,
        operation_manifest_sha256 = BRIDGE.operation_manifest_sha256,
        bridge_version = BRIDGE.runtime_version,
        runtime_tag = BRIDGE.runtime_tag,
        runtime_asset_sha256 = BRIDGE.runtime_asset_sha256,
        release_id = BRIDGE.release_id,
    })
end

local function delivery_token(delivery)
    return table.concat({
        BRIDGE.release_id,
        text_or(delivery.request_id, ""),
        text_or(delivery.delivery_id, ""),
        text_or(delivery.request_hash, ""),
    }, "|")
end

-- Normal play mode can reject Scenario KeyValue access. CMO nevertheless keeps
-- direct named globals across event-script runs, so this cache provides
-- at-most-once execution within the current Lua session. A scenario reload
-- clears it; Host mutation quarantine remains the recovery boundary there.
local function cached_delivery(delivery)
    local cached = CMO_AGENT_BRIDGE_RESPONSE_CACHE
    if type(cached) == "table" and cached.token == delivery_token(delivery) then
        return cached
    end
    return nil
end

local function claim_delivery(delivery)
    local cached = {
        token = delivery_token(delivery),
        phase = "claimed",
        envelope_json = nil,
    }
    CMO_AGENT_BRIDGE_RESPONSE_CACHE = cached
    return cached
end

local function export_cached_response(delivery, cached)
    if cached.phase == "exported" then
        return true
    end
    if cached.phase ~= "prepared" or type(cached.envelope_json) ~= "string" then
        return false
    end
    local written = write_response(delivery.request_id, cached.envelope_json)
    if written then
        cached.phase = "exported"
    end
    return written
end

local function emit_response(delivery, response_envelope)
    local cached = cached_delivery(delivery)
    if cached == nil then
        cached = claim_delivery(delivery)
    end
    cached.envelope_json = Json.encode(response_envelope)
    cached.phase = "prepared"
    return export_cached_response(delivery, cached)
end

local function dispatch()
    local delivery = CMO_AGENT_BRIDGE_DELIVERY
    if type(delivery) ~= "table" or delivery.delivery_kind ~= "request" then
        print("CMO_AGENT_BRIDGE|INVALID_DELIVERY")
        return false
    end

    local cached = cached_delivery(delivery)
    if cached ~= nil then
        if cached.phase == "claimed" then
            print("CMO_AGENT_BRIDGE|DELIVERY_ALREADY_CLAIMED")
            return false
        end
        return export_cached_response(delivery, cached)
    end

    local body_ok, body = pcall(Json.decode, delivery.body_json)
    if not body_ok or type(body) ~= "table" then
        print("CMO_AGENT_BRIDGE|INVALID_BODY|" .. text_or(body, "decode failed"))
        return false
    end

    local scenario_ok, scenario, lineage_id, scenario_time = pcall(scenario_context)
    if not scenario_ok then
        print("CMO_AGENT_BRIDGE|SCENARIO_FAILED|" .. text_or(scenario, "unknown error"))
        return false
    end

    local arguments = body.arguments
    if type(arguments) ~= "table" then
        arguments = Json.object()
    end
    local operation = body.operation
    local activation_id
    if operation == "bridge.status" then
        activation_id = arguments.activation_candidate
    else
        activation_id = body.expected_activation_id
    end
    if activation_id == nil or activation_id == Json.null then
        print("CMO_AGENT_BRIDGE|INVALID_ACTIVATION")
        return false
    end
    activation_id = normalized_uuid(activation_id)

    local identity_matches = delivery.runtime_version == BRIDGE.runtime_version
        and delivery.runtime_tag == BRIDGE.runtime_tag
        and delivery.runtime_asset_sha256 == BRIDGE.runtime_asset_sha256
        and delivery.release_id == BRIDGE.release_id
        and body.protocol == BRIDGE.protocol
        and body.runtime_version == BRIDGE.runtime_version
        and body.runtime_tag == BRIDGE.runtime_tag
        and body.runtime_asset_sha256 == BRIDGE.runtime_asset_sha256
        and body.release_id == BRIDGE.release_id
        and body.operation_manifest_sha256 == BRIDGE.operation_manifest_sha256
    if not identity_matches then
        local failure = response_error(
            "MANIFEST_MISMATCH",
            "host and CMO Lua runtime identities do not match",
            Json.object()
        )
        return emit_response(
            delivery,
            envelope(delivery, lineage_id, activation_id, scenario_time, Json.null, failure)
        )
    end

    local expected_lineage = body.expected_lineage_id
    if expected_lineage ~= nil
        and expected_lineage ~= Json.null
        and normalized_uuid(expected_lineage) ~= lineage_id
    then
        local failure = response_error(
            "SCENARIO_CHANGED",
            "the loaded scenario differs from the active bridge session",
            Json.object({ observed_lineage_id = lineage_id })
        )
        return emit_response(
            delivery,
            envelope(delivery, lineage_id, activation_id, scenario_time, Json.null, failure)
        )
    end

    local handler
    if operation == "bridge.status" then
        handler = function() return status_result(lineage_id, activation_id) end
    elseif operation == "scenario.get" then
        handler = function() return scenario_result(scenario, lineage_id) end
    elseif operation == "scenario.time_compression.set" then
        handler = function() return scenario_time_compression_set_result(arguments) end
    elseif operation == "side.list" then
        handler = function() return side_list_result(arguments) end
    elseif operation == "side.posture.get" then
        handler = function() return side_posture_get_result(arguments) end
    elseif operation == "unit.list" then
        handler = function() return unit_list_result(arguments) end
    elseif operation == "unit.get" then
        handler = function() return unit_get_result(arguments) end
    elseif operation == "unit.combat_status.get" then
        handler = function() return unit_combat_status_result(arguments) end
    elseif operation == "unit.loadout.get" then
        handler = function() return unit_loadout_get_result(arguments) end
    elseif operation == "unit.inventory.get" then
        handler = function() return unit_inventory_get_result(arguments) end
    elseif operation == "unit.set" then
        handler = function() return unit_set_result(arguments) end
    elseif operation == "unit.sensor.set" then
        handler = function() return unit_sensor_set_result(arguments) end
    elseif operation == "unit.magazine.adjust" then
        handler = function() return unit_magazine_adjust_result(arguments) end
    elseif operation == "unit.mount_reload.adjust" then
        handler = function() return unit_mount_reload_adjust_result(arguments) end
    elseif operation == "unit.loadout.set" then
        handler = function() return unit_loadout_set_result(arguments) end
    elseif operation == "unit.launch" then
        handler = function() return unit_launch_result(arguments) end
    elseif operation == "unit.rtb" then
        handler = function() return unit_rtb_result(arguments) end
    elseif operation == "unit.refuel" then
        handler = function() return unit_refuel_result(arguments) end
    elseif operation == "unit.attack_contact" then
        handler = function() return unit_attack_contact_result(arguments) end
    elseif operation == "unit.cargo.transfer" then
        handler = function() return unit_cargo_transfer_result(arguments) end
    elseif operation == "unit.cargo.unload" then
        handler = function() return unit_cargo_unload_result(arguments) end
    elseif operation == "unit.add" then
        handler = function() return unit_add_result(arguments) end
    elseif operation == "unit.assign_mission" then
        handler = function() return unit_assign_mission_result(arguments) end
    elseif operation == "unit.unassign_mission" then
        handler = function() return unit_unassign_mission_result(arguments) end
    elseif operation == "unit.delete" then
        handler = function() return unit_delete_result(arguments) end
    elseif operation == "contact.list" then
        handler = function() return contact_list_result(arguments) end
    elseif operation == "contact.get" then
        handler = function() return contact_get_result(arguments) end
    elseif operation == "contact.posture.set" then
        handler = function() return contact_posture_set_result(arguments) end
    elseif operation == "contact.weapon_allocations.get" then
        handler = function() return contact_weapon_allocations_get_result(arguments) end
    elseif operation == "reference_point.list" then
        handler = function() return reference_point_list_result(arguments) end
    elseif operation == "reference_point.add" then
        handler = function() return reference_point_add_result(arguments) end
    elseif operation == "reference_point.update" then
        handler = function() return reference_point_update_result(arguments) end
    elseif operation == "mission.list" then
        handler = function() return mission_list_result(arguments) end
    elseif operation == "mission.get" then
        handler = function() return mission_get_result(arguments) end
    elseif operation == "mission.create" then
        handler = function() return mission_create_result(arguments) end
    elseif operation == "mission.update" then
        handler = function() return mission_update_result(arguments) end
    elseif operation == "mission.air_refueling.update" then
        handler = function() return mission_air_refueling_update_result(arguments) end
    elseif operation == "mission.flight_plan.list" then
        handler = function() return mission_flight_plan_list_result(arguments) end
    elseif operation == "mission.flight_plan.create" then
        handler = function() return mission_flight_plan_create_result(arguments) end
    elseif operation == "mission.target.add" then
        handler = function() return mission_target_result(arguments, true) end
    elseif operation == "mission.target.remove" then
        handler = function() return mission_target_result(arguments, false) end
    elseif operation == "mission.cargo.update" then
        handler = function() return mission_cargo_update_result(arguments) end
    elseif operation == "mission.delete" then
        handler = function() return mission_delete_result(arguments) end
    elseif operation == "doctrine.get" then
        handler = function() return doctrine_get_result(arguments) end
    elseif operation == "doctrine.set" then
        handler = function() return doctrine_set_result(arguments) end
    elseif operation == "doctrine.wra.get" then
        handler = function() return doctrine_wra_get_result(arguments) end
    elseif operation == "doctrine.wra.set" then
        handler = function() return doctrine_wra_set_result(arguments) end
    elseif operation == "emcon.set" then
        handler = function() return emcon_set_result(arguments) end
    elseif operation == "special_action.list" then
        handler = function() return special_action_list_result(arguments) end
    elseif operation == "special_action.execute" then
        handler = function() return special_action_execute_result(arguments) end
    elseif operation == "lua.call" then
        handler = function() return lua_call_result(arguments) end
    else
        local failure = response_error(
            "POLICY_DENIED",
            "operation is not enabled in the initial CMO Lua runtime",
            Json.object({ operation = text_or(operation, "") })
        )
        return emit_response(
            delivery,
            envelope(delivery, lineage_id, activation_id, scenario_time, Json.null, failure)
        )
    end

    claim_delivery(delivery)
    local ok, result = pcall(handler)
    if not ok then
        local failure = response_error(
            "CMO_LUA_ERROR",
            "CMO Lua handler failed",
            Json.object({ operation = operation, reason = text_or(result, "unknown error") })
        )
        return emit_response(
            delivery,
            envelope(delivery, lineage_id, activation_id, scenario_time, Json.null, failure)
        )
    end
    return emit_response(
        delivery,
        envelope(delivery, lineage_id, activation_id, scenario_time, result, nil)
    )
end

return dispatch()
