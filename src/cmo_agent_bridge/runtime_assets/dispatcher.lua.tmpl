local function unit_sensor_set_result(arguments)
    local unit_guid = tostring(arguments.unit_guid)
    local sensor_guid = tostring(arguments.sensor_guid)
    local descriptor = {
        guid = unit_guid,
        sensors = {
            sensor_guid = sensor_guid,
            sensor_isactive = arguments.active == true,
        },
    }
    if arguments.obey_emcon ~= nil and arguments.obey_emcon ~= Json.null then
        descriptor.obeyEMCON = arguments.obey_emcon == true
    end
    local ok, updated = pcall(ScenEdit_SetUnit, descriptor)
    if not ok or updated == nil or updated == false then
        error("ScenEdit_SetUnit sensor update failed: " .. text_or(updated, "false"))
    end
    local unit = read_unit_by_guid(unit_guid, "sensor unit readback failed")
    local observed_active = nil
    for _, sensor in ipairs(unit_sensor_results(unit)) do
        if sensor.guid == sensor_guid then
            observed_active = sensor.active
            break
        end
    end
    if observed_active == nil or observed_active == Json.null then
        error("updated sensor was not found in inventory readback")
    end
    if observed_active ~= (arguments.active == true) then
        error("sensor active state did not match readback")
    end
    local observed_obey_emcon = nullable_boolean(
        safe_get(unit, { "obeyEMCON", "ObeyEMCON", "obeyemcon" })
    )
    if arguments.obey_emcon ~= nil
        and arguments.obey_emcon ~= Json.null
        and observed_obey_emcon ~= arguments.obey_emcon
    then
        error("obey EMCON state did not match readback")
    end
    return Json.object({
        unit_guid = unit_guid,
        sensor_guid = sensor_guid,
        active = observed_active,
        obey_emcon = observed_obey_emcon,
    })
end

local function inventory_adjustment_descriptor(arguments, container_field, container_guid)
    local descriptor = {
        guid = tostring(arguments.unit_guid),
        wpn_dbid = integer_or(arguments.weapon_dbid, 0),
    }
    descriptor[container_field] = tostring(container_guid)
    local mode = tostring(arguments.mode)
    if mode == "fill" then
        descriptor.fillout = true
    else
        descriptor.number = integer_or(arguments.quantity, 0)
        if mode == "remove" then
            descriptor.remove = true
        end
    end
    return descriptor
end

