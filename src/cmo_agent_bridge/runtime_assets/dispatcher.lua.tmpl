local function mission_full_result(mission, side)
    local mission_class, mission_class_string = mission_class_values(mission)
    local category, parent_task_pool_guid, package_guids = mission_category_values(mission)
    local details = nil
    local patrol_type = Json.null
    local strike_type = Json.null
    local reference_point_guids = Json.null
    local prosecution_zone_reference_point_guids = Json.null
    if mission_class == "patrol" then
        details = safe_get(mission, { "patrolmission", "PatrolMission" })
        patrol_type = normalized_subtype(
            details,
            mission,
            {
                asw = "asw",
                sub = "asw",
                naval = "naval",
                sursea = "naval",
                asuwnaval = "naval",
                aaw = "aaw",
                air = "aaw",
                land = "land",
                surland = "land",
                asuwland = "land",
                mixed = "mixed",
                surmixed = "mixed",
                asuwmixed = "mixed",
                sead = "sead",
                sea = "sea",
                seacontrol = "sea",
            }
        )
        local zone = safe_get(details, { "PatrolZone", "patrolzone" })
        if zone ~= nil then
            reference_point_guids = collect_reference_point_guids(side, zone)
        end
        local prosecution_zone = safe_get(
            details,
            { "ProsecutionZone", "prosecutionzone" }
        )
        if prosecution_zone ~= nil then
            prosecution_zone_reference_point_guids = collect_reference_point_guids(
                side,
                prosecution_zone
            )
        end
    elseif mission_class == "strike" then
        details = safe_get(mission, { "strikemission", "StrikeMission" })
        strike_type = normalized_subtype(
            details,
            mission,
            {
                air = "air",
                aaw = "air",
                airintercept = "air",
                land = "land",
                surland = "land",
                landstrike = "land",
                sea = "sea",
                naval = "sea",
                sursea = "sea",
                maritimestrike = "sea",
                sub = "sub",
                asw = "sub",
                substrike = "sub",
            }
        )
    elseif mission_class == "support" then
        details = safe_get(mission, { "supportmission", "SupportMission" })
        local zone = safe_get(details, { "Zone", "zone" })
        if zone ~= nil then
            reference_point_guids = collect_reference_point_guids(side, zone)
        end
    elseif mission_class == "ferry" then
        details = safe_get(mission, { "ferrymission", "FerryMission" })
    elseif mission_class == "mining" then
        details = safe_get(mission, { "minemission", "MineMission" })
        local zone = safe_get(details, { "Zone", "zone" })
        if zone ~= nil then
            reference_point_guids = collect_reference_point_guids(side, zone)
        end
    elseif mission_class == "mine_clearing" then
        details = safe_get(mission, { "mineclearmission", "MineClearMission" })
        local zone = safe_get(details, { "Zone", "zone" })
        if zone ~= nil then
            reference_point_guids = collect_reference_point_guids(side, zone)
        end
    elseif mission_class == "cargo" then
        details = safe_get(mission, { "cargomission", "CargoMission" })
        local zone = safe_get(details, { "Zone", "zone" })
        if zone ~= nil then
            reference_point_guids = collect_reference_point_guids(side, zone)
        end
    end

    local flight_size = Json.null
    local use_flight_size = Json.null
    local minimum_aircraft_required = Json.null
    local on_station = Json.null
    local one_time_only = Json.null
    local preplanned_only = Json.null
    local one_third_rule = Json.null
    local destination_guid = Json.null
    local loop_type = Json.null
    local active_emcon = Json.null
    local check_opa = Json.null
