local function unit_refuel_result(arguments)
    local unit_guid = tostring(arguments.unit_guid)
    local descriptor = { guid = unit_guid }
    if arguments.tanker_guid ~= nil and arguments.tanker_guid ~= Json.null then
        descriptor.tanker = tostring(arguments.tanker_guid)
    elseif arguments.tanker_mission_guids ~= nil
        and arguments.tanker_mission_guids ~= Json.null
    then
        descriptor.missions = ordered_strings(arguments.tanker_mission_guids)
    end
    local ok, message = pcall(ScenEdit_RefuelUnit, descriptor)
    if not ok then
        error("ScenEdit_RefuelUnit failed: " .. text_or(message, "unknown error"))
    end
    if text_or(message, "") ~= "" then
        error("ScenEdit_RefuelUnit rejected command: " .. text_or(message, "unknown error"))
    end
    return unit_command_snapshot(unit_guid, "refuel")
end

local function unit_attack_contact_result(arguments)
    local side = resolve_side(arguments)
    local side_selector = side_api_selector(arguments, side)
    local attacker_guid = tostring(arguments.attacker_unit_guid)
    local contact_guid = tostring(arguments.contact_guid)
    local attacker_before = read_unit_by_guid(attacker_guid, "attacker was not found")
    local attacker_side = safe_get(attacker_before, { "side", "Side" })
    local expected_side_guid = lower_text(object_guid(side))
    local attacker_side_guid = lower_text(object_guid(attacker_side))
    local expected_side_name = lower_text(object_name(side))
    local attacker_side_name = lower_text(object_name(attacker_side))
    local same_side = false
    if expected_side_guid ~= "" and attacker_side_guid ~= "" then
        same_side = expected_side_guid == attacker_side_guid
    elseif expected_side_name ~= "" and attacker_side_name ~= "" then
        same_side = expected_side_name == attacker_side_name
    end
    if not same_side then
        error("attacker does not belong to the contact-observing side")
    end
    local contact_ok, contact = pcall(
        ScenEdit_GetContact,
        { side = side_selector, guid = contact_guid }
    )
    if not contact_ok or contact == nil then
        error("contact was not found for the observing side")
    end

    local mode_values = { auto = 0, manual_weapon = 1, manual_target = 2 }
    local mode = tostring(arguments.mode)
    local options = { mode = mode_values[mode] }
    if mode == "manual_weapon" then
        options.weapon = integer_or(arguments.weapon_dbid, 0)
        options.qty = integer_or(arguments.quantity, 0)
        if arguments.mount_dbid ~= nil and arguments.mount_dbid ~= Json.null then
            options.mount = integer_or(arguments.mount_dbid, 0)
        end
    end
    local attack_ok, assigned = pcall(
        ScenEdit_AttackContact,
        attacker_guid,
        contact_guid,
        options
    )
    if not attack_ok or assigned ~= true then
        error("ScenEdit_AttackContact failed: " .. text_or(assigned, "false"))
    end

    local attacker = read_unit_by_guid(attacker_guid, "attacker readback failed")
    local contact_read_ok, actual_contact = pcall(
        ScenEdit_GetContact,
        { side = side_selector, guid = contact_guid }
    )
    if not contact_read_ok or actual_contact == nil then
        actual_contact = contact
    end
    local primary_target_guid = object_guid(
        safe_get(attacker, { "target", "Target" })
    )
    if primary_target_guid == "" then
        primary_target_guid = Json.null
    end
    local targeted_by = collect_identifiers(
        safe_get(actual_contact, { "targetedBy", "TargetedBy", "targetedby" })
    )
    return Json.object({
        attacker_unit_guid = text_or(
            safe_get(attacker, { "guid", "Guid", "GUID" }),
            attacker_guid
        ),
        contact_guid = contact_guid,
        mode = mode,
        accepted = true,
        primary_target_contact_guid = primary_target_guid,
        firing_at_contact_guids = collect_identifiers(
            safe_get(attacker, { "firingAt", "FiringAt", "firingat" })
        ),
        targeted_by_attacker = contains_identifier(targeted_by, attacker_guid),
    })
end

local function course_descriptor(arguments)
    if arguments.course == nil or arguments.course == Json.null then
        return nil
    end
    local descriptor_course = {}
    for index, waypoint in ipairs(arguments.course) do
        local descriptor_waypoint = {
            latitude = number_or(waypoint.latitude, 0),
            longitude = number_or(waypoint.longitude, 0),
        }
        local altitude = waypoint.altitude
        if altitude ~= nil and altitude ~= Json.null then
            descriptor_waypoint.altitude = number_or(altitude, 0)
        end
        descriptor_course[index] = descriptor_waypoint
    end
    return descriptor_course
end

local function normalized_unit_course(value)
    if value == nil or value == Json.null then
        return Json.null
    end
    local indexed = {}
    local seen = 0
    local ok = pcall(function()
        for key, waypoint in pairs(value) do
            seen = seen + 1
            local latitude = nullable_number(safe_get(waypoint, { "latitude", "Latitude" }))
            local longitude = nullable_number(safe_get(waypoint, { "longitude", "Longitude" }))
            if latitude ~= Json.null and longitude ~= Json.null then
                indexed[#indexed + 1] = {
                    order = tonumber(key) or (#indexed + 1),
                    waypoint = {
                        latitude = latitude,
                        longitude = longitude,
                        altitude = nullable_number(
                            safe_get(waypoint, { "altitude", "Altitude" })
                        ),
                    },
                }
            end
        end
    end)
    if not ok or (seen > 0 and #indexed == 0) then
        return Json.null
    end
    table.sort(indexed, function(left, right) return left.order < right.order end)
    local result = Json.array()
    for _, item in ipairs(indexed) do
        result[#result + 1] = item.waypoint
    end
    return result
end

local function unit_set_result(arguments)
    local unit_guid = tostring(arguments.unit_guid)
    local descriptor = { guid = unit_guid }
    local has_update = false

    if arguments.name ~= nil and arguments.name ~= Json.null then
        descriptor.newname = tostring(arguments.name)
        has_update = true
    end
    for _, field in ipairs({ "speed", "altitude", "depth", "heading" }) do
        local value = arguments[field]
        if value ~= nil and value ~= Json.null then
            descriptor[field] = number_or(value, 0)
            has_update = true
        end
    end
    if arguments.throttle ~= nil and arguments.throttle ~= Json.null then
        descriptor.throttle = tostring(arguments.throttle)
        has_update = true
    end
    local scalar_mapping = {
        manual_throttle = "manualthrottle",
        manual_speed = "manualspeed",
        manual_altitude = "manualaltitude",
    }
    for public_name, cmo_name in pairs(scalar_mapping) do
        local value = arguments[public_name]
        if value ~= nil and value ~= Json.null then
            descriptor[cmo_name] = value
            has_update = true
        end
    end
    if arguments.desired_heading ~= nil
        and arguments.desired_heading ~= Json.null
    then
        descriptor.desiredHeading = number_or(arguments.desired_heading, 0)
        has_update = true
    end
    local boolean_mapping = {
        force_speed = "forceSpeed",
        move_to = "moveto",
        hold_position = "holdPosition",
        hold_fire = "holdFire",
        sprint_drift = "sprintDrift",
        avoid_cavitation = "avoidcavitation",
        obey_emcon = "obeyEMCON",
    }
    for public_name, cmo_name in pairs(boolean_mapping) do
        local value = arguments[public_name]
        if value ~= nil and value ~= Json.null then
            descriptor[cmo_name] = value == true
            has_update = true
        end
    end
    local descriptor_course = course_descriptor(arguments)
    if descriptor_course ~= nil then
        descriptor.course = descriptor_course
        has_update = true
    end
    if not has_update then
        error("unit.set requires at least one non-null update")
    end

    local ok, updated = pcall(ScenEdit_SetUnit, descriptor)
    if not ok or updated == nil or updated == false then
        error("ScenEdit_SetUnit failed: " .. text_or(updated, "no unit returned"))
    end

    local actual = updated
    local read_ok, reread = pcall(ScenEdit_GetUnit, { guid = unit_guid })
    if read_ok and reread ~= nil then
        actual = reread
    end
    return Json.object({
        unit_guid = text_or(safe_get(actual, { "guid", "Guid", "GUID" }), unit_guid),
        name = text_or(safe_get(actual, { "name", "Name" }), ""),
        speed = nullable_number(safe_get(actual, { "speed", "Speed" })),
        altitude = nullable_number(safe_get(actual, { "altitude", "Altitude" })),
        depth = nullable_number(safe_get(actual, { "depth", "Depth" })),
        heading = nullable_number(safe_get(actual, { "heading", "Heading" })),
        throttle = nullable_text(safe_get(actual, { "throttle", "Throttle" })),
        force_speed = nullable_boolean(
            safe_get(actual, { "forceSpeed", "ForceSpeed", "forcespeed" })
        ),
        desired_heading = nullable_number(
            safe_get(actual, { "desiredHeading", "DesiredHeading", "desiredheading" })
        ),
        move_to = nullable_boolean(
            safe_get(actual, { "moveto", "moveTo", "MoveTo" })
        ),
        manual_throttle = nullable_scalar(
            safe_get(
                actual,
                { "manualThrottle", "manualthrottle", "ManualThrottle" }
            )
        ),
        manual_speed = nullable_scalar(
            safe_get(actual, { "manualSpeed", "manualspeed", "ManualSpeed" })
        ),
        manual_altitude = nullable_scalar(
            safe_get(
                actual,
                { "manualAltitude", "manualaltitude", "ManualAltitude" }
            )
        ),
        hold_position = nullable_boolean(
            safe_get(actual, { "holdPosition", "holdposition", "HoldPosition" })
        ),
        hold_fire = nullable_boolean(safe_get(actual, { "holdFire", "HoldFire" })),
        sprint_drift = nullable_boolean(
            safe_get(actual, { "sprintDrift", "SprintDrift", "sprintdrift" })
        ),
        avoid_cavitation = nullable_boolean(
            safe_get(
                actual,
                { "avoidCavitation", "avoidcavitation", "AvoidCavitation" }
            )
        ),
        obey_emcon = nullable_boolean(
            safe_get(actual, { "obeyEMCON", "ObeyEMCON", "obeyemcon" })
        ),
        course = normalized_unit_course(safe_get(actual, { "course", "Course" })),
    })
end

local function unit_add_result(arguments)
    local side = resolve_side(arguments)
    local side_selector = side_api_selector(arguments, side)
    local descriptor = {
        side = side_selector,
        type = tostring(arguments.unit_type),
        dbid = integer_or(arguments.dbid, 0),
        unitname = tostring(arguments.name),
    }
    if arguments.base_guid ~= nil and arguments.base_guid ~= Json.null then
        descriptor.base = tostring(arguments.base_guid)
    else
        descriptor.latitude = number_or(arguments.latitude, 0)
        descriptor.longitude = number_or(arguments.longitude, 0)
    end
    if arguments.altitude ~= nil and arguments.altitude ~= Json.null then
        descriptor.altitude = number_or(arguments.altitude, 0)
    end
    if arguments.loadout_dbid ~= nil and arguments.loadout_dbid ~= Json.null then
        descriptor.loadoutid = integer_or(arguments.loadout_dbid, 0)
    end

    local ok, added = pcall(ScenEdit_AddUnit, descriptor)
    if not ok or added == nil or added == false then
        error("ScenEdit_AddUnit failed: " .. text_or(added, "no unit returned"))
    end
    local unit_guid = object_guid(added)
    if unit_guid == "" then
        error("added unit GUID could not be read back")
    end
    local finalize_ok, finalized = pcall(function()
        local read_ok, actual = pcall(ScenEdit_GetUnit, { guid = unit_guid })
        if not read_ok or actual == nil then
            error("added unit could not be read back")
        end
        local result = unit_full_result(actual, "")
        if result.guid == "" or result.dbid <= 0 then
            error("added unit identity could not be read back")
        end
        local latitude = nullable_number(result.latitude)
        local longitude = nullable_number(result.longitude)
        if latitude == Json.null or longitude == Json.null then
            error("added unit coordinates could not be read back")
        end
        local side_guid = object_guid(side)
        if side_guid == "" then
            error("added unit side GUID could not be read back")
        end
        return Json.object({
            unit_guid = result.guid,
            name = result.name,
            side_guid = side_guid,
            dbid = result.dbid,
            latitude = latitude,
            longitude = longitude,
        })
    end)
    if not finalize_ok then
        pcall(ScenEdit_DeleteUnit, { side = side_selector, guid = unit_guid })
        error(text_or(finalized, "added unit readback failed"))
    end
    return finalized
end

local function unit_assign_mission_result(arguments)
    local unit_guid = tostring(arguments.unit_guid)
    local mission_guid = tostring(arguments.mission_guid)
    local escort = arguments.escort == true
    local ok, assigned = pcall(
        ScenEdit_AssignUnitToMission,
        unit_guid,
        mission_guid,
        escort
    )
    if not ok or assigned ~= true then
        error("ScenEdit_AssignUnitToMission failed: " .. text_or(assigned, "false"))
    end
    local read_ok, unit = pcall(ScenEdit_GetUnit, { guid = unit_guid })
    if not read_ok or unit == nil then
        error("assigned unit could not be read back")
    end
    local observed_unit_guid = object_guid(unit)
    if observed_unit_guid == "" then
        error("assigned unit GUID could not be read back")
    end
    local mission = safe_get(unit, { "mission", "Mission" })
    local observed_mission_guid = object_guid(mission)
    if lower_text(observed_mission_guid) ~= lower_text(mission_guid) then
        error("assigned mission did not match the requested mission")
    end
    local raw_escort = safe_get(unit, { "isEscort", "isescort", "IsEscort" })
    if raw_escort == nil then
        error("assigned escort status could not be read back")
    end
    local observed_escort = boolean_or(raw_escort, not escort)
    if observed_escort ~= escort then
        error("assigned escort status did not match the request")
    end
    return Json.object({
        unit_guid = observed_unit_guid,
        mission_guid = observed_mission_guid,
        escort = observed_escort,
    })
end

local function unit_unassign_mission_result(arguments)
    local unit_guid = tostring(arguments.unit_guid)
    local ok, updated = pcall(ScenEdit_SetUnit, { guid = unit_guid, unassign = true })
    if not ok or updated == nil or updated == false then
        error("ScenEdit_SetUnit unassign failed: " .. text_or(updated, "no unit returned"))
    end
    local read_ok, actual = pcall(ScenEdit_GetUnit, { guid = unit_guid })
    if not read_ok or actual == nil then
        error("unassigned unit could not be read back")
    end
    local observed_guid = object_guid(actual)
    if observed_guid == "" then
        error("unassigned unit GUID could not be read back")
    end
    local mission = safe_get(actual, { "mission", "Mission" })
    if mission ~= nil and mission ~= Json.null then
        local mission_guid = object_guid(mission)
        local mission_name = object_name(mission)
        if mission_guid ~= "" or mission_name ~= "" then
            error("unit remained assigned after unassign")
        end
    end
    local raw_escort = safe_get(actual, { "isEscort", "isescort", "IsEscort" })
    if raw_escort ~= nil and boolean_or(raw_escort, true) then
        error("unit remained an escort after unassign")
    end
    return Json.object({
        unit_guid = observed_guid,
        mission_guid = Json.null,
        escort = false,
    })
end

local function unit_delete_result(arguments)
    require_confirmation_proof(arguments)
    local unit_guid = tostring(arguments.unit_guid)
    local read_ok, unit = pcall(ScenEdit_GetUnit, { guid = unit_guid })
    if not read_ok or unit == nil then
        error("unit to delete was not found")
    end
    local deleted_name = object_name(unit)

    local side = safe_get(unit, { "side", "Side" })
    local side_selector = object_guid(side)
    if side_selector == "" then
        side_selector = object_name(side)
    end
    if side_selector == "" then
        error("unit side could not be read before deletion")
    end

    local delete_ok, deleted = pcall(
        ScenEdit_DeleteUnit,
        { side = side_selector, guid = unit_guid }
    )
    if not delete_ok or deleted == nil or deleted == false then
        error("ScenEdit_DeleteUnit failed: " .. text_or(deleted, "false"))
    end

    local verify_ok, remaining = pcall(ScenEdit_GetUnit, { guid = unit_guid })
    if verify_ok and remaining ~= nil then
        error("unit remained present after deletion")
    end
    return Json.object({
        deleted_guid = unit_guid,
        deleted_name = deleted_name,
        object_kind = "unit",
    })
end

