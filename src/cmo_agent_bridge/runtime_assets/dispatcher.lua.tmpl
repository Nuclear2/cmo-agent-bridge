local MISSION_CLASS_BY_NUMBER = {
    [0] = "none",
    [1] = "strike",
    [2] = "patrol",
    [3] = "support",
    [4] = "ferry",
    [5] = "mining",
    [6] = "mine_clearing",
    [7] = "escort",
    [8] = "cargo",
}

local MISSION_CLASS_BY_TEXT = {
    none = "none",
    strike = "strike",
    patrol = "patrol",
    support = "support",
    ferry = "ferry",
    mining = "mining",
    mineclearing = "mine_clearing",
    escort = "escort",
    cargo = "cargo",
}

local function mission_class_values(mission)
    local raw_number = tonumber(safe_get(mission, { "type", "Type" }))
    local raw_text = text_or(safe_get(mission, { "typeS", "types", "TypeS" }), "")
    local class_name = raw_number ~= nil and MISSION_CLASS_BY_NUMBER[math.floor(raw_number)] or nil
    if class_name == nil then
        local key = string.lower(string.gsub(raw_text, "[^%w]", ""))
        class_name = MISSION_CLASS_BY_TEXT[key]
    end
    if class_name == nil then
        class_name = "none"
    end
    if raw_text == "" then
        raw_text = class_name
    end
    return class_name, raw_text
end

local function normalized_subtype(details, mission, aliases)
    local raw = safe_get(
        details,
        { "subtype", "Subtype", "type", "Type", "PatrolType", "patroltype" }
    )
    if raw == nil then
        raw = safe_get(mission, { "subtype", "Subtype" })
    end
    local subtype = string.lower(string.gsub(text_or(raw, ""), "[^%w]", ""))
    if aliases[subtype] ~= nil then
        return aliases[subtype]
    end
    for alias, normalized in pairs(aliases) do
        if string.find(subtype, alias, 1, true) ~= nil then
            return normalized
        end
    end
    return Json.null
end

local function nullable_flight_size(value)
    local numeric = nullable_integer(value)
    if numeric == Json.null then
        numeric = nullable_integer(safe_get(value, { "value__", "Value", "value" }))
    end
    if numeric ~= Json.null then
        return numeric
    end
    local rendered = value
    local rendered_ok, rendered_value = pcall(function() return value:ToString() end)
    if rendered_ok and rendered_value ~= nil then
        rendered = rendered_value
    end
    local key = string.lower(string.gsub(text_or(rendered, ""), "[^%w]", ""))
    local sizes = {
        none = 0,
        singleaircraft = 1,
        oneaircraft = 1,
        twoaircraft = 2,
        threeaircraft = 3,
        fouraircraft = 4,
        sixaircraft = 6,
    }
    if sizes[key] ~= nil then
        return sizes[key]
    end
    for name, size in pairs(sizes) do
        if string.find(key, name, 1, true) ~= nil then
            return size
        end
    end
    return Json.null
end

local function nullable_flight_quantity(value)
    local numeric = nullable_integer(value)
    if numeric == Json.null then
        numeric = nullable_integer(safe_get(value, { "value__", "Value", "value" }))
    end
    if numeric ~= Json.null then
        return numeric
    end
    local rendered = value
    local rendered_ok, rendered_value = pcall(function() return value:ToString() end)
    if rendered_ok and rendered_value ~= nil then
        rendered = rendered_value
    end
    local key = string.lower(string.gsub(text_or(rendered, ""), "[^%w]", ""))
    if key == "all" or string.find(key, "all", 1, true) ~= nil then
        return "all"
    end
    if key == "nopreferences" or key == "none" then
        return 0
    end
    local quantities = {
        flightx1 = 1,
        flightx2 = 2,
        flightx3 = 3,
        flightx4 = 4,
        flightx6 = 6,
        flightx8 = 8,
        flightx12 = 12,
    }
    for name, quantity in pairs(quantities) do
        if string.find(key, name, 1, true) ~= nil then
            return quantity
        end
    end
    return Json.null
end

local function nullable_loop_type(value)
    local numeric = nullable_enum_integer(value)
    if numeric ~= Json.null then
        if numeric >= 0 and numeric <= 2 then
            return numeric
        end
        return Json.null
    end
    local rendered = value
    local rendered_ok, rendered_value = pcall(function() return value:ToString() end)
    if rendered_ok and rendered_value ~= nil then
        rendered = rendered_value
    end
    local key = string.lower(string.gsub(text_or(rendered, ""), "[^%w]", ""))
    if key == "random" or string.find(key, "continuous", 1, true) ~= nil then
        return 0
    elseif string.find(key, "repeat", 1, true) ~= nil
        or string.find(key, "single", 1, true) ~= nil
    then
        return 1
    elseif string.find(key, "chainsaw", 1, true) ~= nil then
        return 2
    end
    return Json.null
end

