local function mission_list_result(arguments)
    local side = resolve_side(arguments)
    local selector = side_api_selector(arguments, side)
    local ok, wrappers = pcall(ScenEdit_GetMissions, selector)
    if not ok or wrappers == nil then
        error("ScenEdit_GetMissions failed: " .. text_or(wrappers, "no missions returned"))
    end
    local normalized = {}
    for _, mission in ipairs(collect(wrappers)) do
        local result = mission_full_result(mission, side)
        if arguments.mission_class == nil
            or arguments.mission_class == Json.null
            or lower_text(result.mission_class) == lower_text(arguments.mission_class)
        then
            if arguments.category == nil
                or arguments.category == Json.null
                or lower_text(result.category) == lower_text(arguments.category)
            then
                normalized[#normalized + 1] = result
            end
        end
    end
    return page_and_project(normalized, arguments, MISSION_FIELDS, "mission.list")
end

local function mission_get_result(arguments)
    local side = resolve_side(arguments)
    local selector = side_api_selector(arguments, side)
    local mission_selector = arguments.mission_guid
    if mission_selector == nil or mission_selector == Json.null then
        mission_selector = arguments.mission_name
    end
    local ok, mission = pcall(ScenEdit_GetMission, selector, tostring(mission_selector))
    if not ok then
        error("ScenEdit_GetMission failed: " .. text_or(mission, "unknown error"))
    end
    if mission == nil then
        error("mission was not found")
    end
    return Json.object(mission_full_result(mission, side))
end

local function mission_readback(side, side_selector, mission_guid)
    local ok, mission = pcall(ScenEdit_GetMission, side_selector, mission_guid)
    if not ok or mission == nil then
        error("mission could not be read back: " .. text_or(mission, "not found"))
    end
    return mission, mission_full_result(mission, side)
end

local function mission_create_result(arguments)
    local side = resolve_side(arguments)
    local side_selector = side_api_selector(arguments, side)
    local details = arguments.details
    local mission_class = lower_text(details.mission_class)
    local options = {}
    local category = arguments.category
    if category == nil or category == Json.null then
        category = "mission"
    else
        category = tostring(category)
    end
    local expected_parent_task_pool_guid = Json.null
    if category == "task_pool" then
        options.category = "taskpool"
    elseif category == "package" then
        options.category = "package"
        expected_parent_task_pool_guid = tostring(arguments.parent_task_pool_guid)
        options.pool = expected_parent_task_pool_guid
    elseif category ~= "mission" then
        error("unsupported mission category")
    end
    local expected_zone = nil
    local expected_targets = nil
    local expected_destination = nil
    local expected_cargo_subtype = nil
    local post_create_options = { isactive = false }

    if mission_class == "patrol" then
        options.type = tostring(details.patrol_type)
        expected_zone = ordered_strings(details.reference_point_guids)
        options.zone = expected_zone
    elseif mission_class == "support" then
        expected_zone = ordered_strings(details.reference_point_guids)
        options.zone = expected_zone
    elseif mission_class == "strike" then
        options.type = tostring(details.strike_type)
        expected_targets = ordered_strings(details.target_guids)
    elseif mission_class == "ferry" then
        expected_destination = tostring(details.destination_guid)
        options.destination = expected_destination
    elseif mission_class == "mining" then
        expected_zone = ordered_strings(details.reference_point_guids)
        options.zone = expected_zone
    elseif mission_class == "mine_clearing" then
        expected_zone = ordered_strings(details.reference_point_guids)
        post_create_options.Zone = expected_zone
    elseif mission_class == "cargo" then
        expected_cargo_subtype = tostring(details.cargo_subtype)
        post_create_options.subtype = expected_cargo_subtype
        if details.reference_point_guids ~= nil
            and details.reference_point_guids ~= Json.null
        then
            expected_zone = ordered_strings(details.reference_point_guids)
            options.zone = expected_zone
        end
        if details.destination_guid ~= nil
            and details.destination_guid ~= Json.null
        then
            expected_destination = tostring(details.destination_guid)
            post_create_options.DestinationUnitID = expected_destination
        end
    else
        error("unsupported mission class")
    end

    local class_names = {
        patrol = "Patrol",
        support = "Support",
        strike = "Strike",
        ferry = "Ferry",
        mining = "Mining",
        mine_clearing = "MineClearing",
        cargo = "Cargo",
    }
    local class_name = class_names[mission_class]
    local ok, added = pcall(
        ScenEdit_AddMission,
        side_selector,
        tostring(arguments.name),
        class_name,
        options
    )
    if not ok or added == nil or added == false then
        error("ScenEdit_AddMission failed: " .. text_or(added, "no mission returned"))
    end
    local mission_guid = object_guid(added)
    if mission_guid == "" then
        error("added mission GUID could not be read back")
    end

    local finalize_ok, finalized = pcall(function()
        local inactive_ok, inactive = pcall(
            ScenEdit_SetMission,
            side_selector,
            mission_guid,
            post_create_options
        )
        if not inactive_ok or inactive == nil or inactive == false then
            error("new mission could not be made inactive")
        end

        if expected_targets ~= nil and #expected_targets > 0 then
            local targets = {}
            for index, target_guid in ipairs(expected_targets) do
                targets[index] = target_guid
            end
            local target_ok, assigned = pcall(
                ScenEdit_AssignUnitAsTarget,
                targets,
                mission_guid
            )
            if not target_ok or assigned == nil or assigned == false then
                error(
                    "ScenEdit_AssignUnitAsTarget failed: "
                        .. text_or(assigned, "no targets returned")
                )
            end
        end

        local _, actual = mission_readback(side, side_selector, mission_guid)
        if actual.guid == "" or actual.mission_class ~= mission_class then
            error("added mission identity did not match readback")
        end
        if actual.category ~= category then
            error("added mission category did not match readback")
        end
        if category == "package"
            and lower_text(actual.parent_task_pool_guid)
                ~= lower_text(expected_parent_task_pool_guid)
        then
            error("added package parent task pool did not match readback")
        end
        if actual.active ~= false then
            error("new mission did not remain inactive")
        end
        if expected_zone ~= nil then
            local observed_zone = actual.reference_point_guids
            if observed_zone == Json.null
                or not same_identifiers_in_order(observed_zone, expected_zone)
            then
                error("added mission zone did not match readback")
            end
        end
        if expected_targets ~= nil then
            for _, target_guid in ipairs(expected_targets) do
                if not contains_identifier(actual.target_guids, target_guid) then
                    error("added strike target did not match readback")
                end
            end
        end
        if expected_destination ~= nil
            and actual.destination_guid ~= expected_destination
        then
            error("added mission destination did not match readback")
        end
        if expected_cargo_subtype ~= nil
            and lower_text(actual.cargo_subtype) ~= lower_text(expected_cargo_subtype)
        then
            error("added cargo mission subtype did not match readback")
        end
        local subtype = Json.null
        if mission_class == "patrol" then
            subtype = actual.patrol_type
        elseif mission_class == "strike" then
            subtype = actual.strike_type
        elseif mission_class == "cargo" then
            subtype = actual.cargo_subtype
        end
        local side_guid = object_guid(side)
        if side_guid == "" then
            error("added mission side GUID could not be read back")
        end
        return Json.object({
            mission_guid = actual.guid,
            name = actual.name,
            side_guid = side_guid,
            mission_class = actual.mission_class,
            subtype = subtype,
            category = actual.category,
            parent_task_pool_guid = actual.parent_task_pool_guid,
            active = false,
        })
    end)
    if not finalize_ok then
        pcall(ScenEdit_DeleteMission, side_selector, mission_guid)
        error(text_or(finalized, "added mission readback failed"))
    end
    return finalized
end

local function mission_update_result(arguments)
    local side = resolve_side(arguments)
    local side_selector = side_api_selector(arguments, side)
    local mission_guid = tostring(arguments.mission_guid)
    local current, _ = mission_readback(side, side_selector, mission_guid)
    local mission_class = mission_class_values(current)
    local descriptor = {}

    if arguments.active ~= nil and arguments.active ~= Json.null then
        descriptor.isactive = arguments.active == true
    end
    if arguments.start_time ~= nil and arguments.start_time ~= Json.null then
        descriptor.starttime = tostring(arguments.start_time)
    end
    if arguments.end_time ~= nil and arguments.end_time ~= Json.null then
        descriptor.endtime = tostring(arguments.end_time)
    end
    if arguments.flight_size ~= nil and arguments.flight_size ~= Json.null then
        if mission_class == "strike" then
            descriptor.StrikeFlightSize = integer_or(arguments.flight_size, 1)
        else
            descriptor.FlightSize = integer_or(arguments.flight_size, 1)
        end
    end
    if arguments.use_flight_size ~= nil and arguments.use_flight_size ~= Json.null then
        if mission_class == "strike" then
            descriptor.StrikeUseFlightSize = arguments.use_flight_size == true
        else
            descriptor.UseFlightSize = arguments.use_flight_size == true
        end
    end
    if arguments.minimum_aircraft_required ~= nil
        and arguments.minimum_aircraft_required ~= Json.null
    then
        if mission_class == "strike" then
            descriptor.StrikeMinAircraftReq = integer_or(
                arguments.minimum_aircraft_required,
                0
            )
        else
            descriptor.MinAircraftReq = integer_or(
                arguments.minimum_aircraft_required,
                0
            )
        end
    end
    if arguments.on_station ~= nil and arguments.on_station ~= Json.null then
        if mission_class ~= "patrol" and mission_class ~= "support" then
            error("only patrol and support missions support on-station requirements")
        end
        descriptor.OnStation = integer_or(arguments.on_station, 0)
    end
    if arguments.one_time_only ~= nil and arguments.one_time_only ~= Json.null then
        if mission_class == "support" then
            descriptor.OneTimeOnly = arguments.one_time_only == true
        elseif mission_class == "strike" then
            descriptor.StrikeOneTimeOnly = arguments.one_time_only == true
        else
            error("mission class does not support one-time-only execution")
        end
    end
    if arguments.preplanned_only ~= nil and arguments.preplanned_only ~= Json.null then
        if mission_class ~= "strike" then
            error("only strike missions support preplanned-only execution")
        end
        descriptor.StrikePreplan = arguments.preplanned_only == true
    end
    if arguments.one_third_rule ~= nil and arguments.one_third_rule ~= Json.null then
        if mission_class ~= "patrol"
            and mission_class ~= "support"
            and mission_class ~= "mining"
            and mission_class ~= "mine_clearing"
            and mission_class ~= "cargo"
        then
            error("mission class does not support the one-third rule")
        end
        descriptor.OneThirdRule = arguments.one_third_rule == true
    end
    if arguments.reference_point_guids ~= nil
        and arguments.reference_point_guids ~= Json.null
    then
        local zone = ordered_strings(arguments.reference_point_guids)
        if mission_class == "patrol" then
            descriptor.PatrolZone = zone
        elseif mission_class == "support"
            or mission_class == "mining"
            or mission_class == "mine_clearing"
            or mission_class == "cargo"
        then
            descriptor.Zone = zone
        else
            error("mission class does not support a reference-point zone update")
        end
    end
    if arguments.prosecution_zone_reference_point_guids ~= nil
        and arguments.prosecution_zone_reference_point_guids ~= Json.null
    then
        if mission_class ~= "patrol" then
            error("only patrol missions support a prosecution zone")
        end
        descriptor.ProsecutionZone = ordered_strings(
            arguments.prosecution_zone_reference_point_guids
        )
    end

    local direct_mapping = {
        loop_type = "LoopType",
        transit_throttle_aircraft = "TransitThrottleAircraft",
