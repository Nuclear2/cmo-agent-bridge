local function mission_category_values(mission)
    local package_list = safe_get(
        mission,
        { "packagelist", "PackageList", "packageList" }
    )
    local package_guids = collect_identifiers(package_list)
    local parent = safe_get(
        mission,
        {
            "parentTaskPool",
            "ParentTaskPool",
            "parenttaskpool",
            "taskPool",
            "TaskPool",
        }
    )
    local parent_guid = normalized_object_reference(parent)
    local category = "mission"
    if parent_guid ~= Json.null then
        category = "package"
    elseif package_list ~= nil and package_list ~= Json.null then
        category = "task_pool"
    else
        local raw = safe_get(
            mission,
            {
                "category",
                "Category",
                "missioncategory",
                "MissionCategory",
            }
        )
        local key = string.lower(string.gsub(text_or(raw, ""), "[^%w]", ""))
        if string.find(key, "taskpool", 1, true) ~= nil then
            category = "task_pool"
        elseif string.find(key, "package", 1, true) ~= nil then
            category = "package"
        end
    end
    return category, parent_guid, package_guids
end

