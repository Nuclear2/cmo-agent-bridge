local function unit_fuel_results(unit)
    local fuels = safe_get(unit, { "fuels", "Fuels", "fuel", "Fuel" })
    local results = {}
    if fuels ~= nil and fuels ~= Json.null then
        pcall(function()
            for key, fuel in pairs(fuels) do
                local current = number_or(
                    safe_get(fuel, { "current", "Current", "quantity", "Quantity" }),
                    0
                )
                local maximum = number_or(
                    safe_get(fuel, { "max", "Max", "maximum", "Maximum" }),
                    0
                )
                local percent = Json.null
                if maximum > 0 then
                    percent = current * 100 / maximum
                end
                local type_code = integer_or(
                    safe_get(fuel, { "type", "Type", "type_code", "TypeCode" }),
                    integer_or(key, 0)
                )
                results[#results + 1] = {
                    type_code = type_code,
                    name = text_or(safe_get(fuel, { "name", "Name" }), ""),
                    current = current,
                    max = maximum,
                    percent = percent,
                }
            end
        end)
    end
    table.sort(results, function(left, right)
        if left.type_code == right.type_code then
            return left.name < right.name
        end
        return left.type_code < right.type_code
    end)
    local output = Json.array()
    for _, result in ipairs(results) do
        output[#output + 1] = Json.object(result)
    end
    return output
end

