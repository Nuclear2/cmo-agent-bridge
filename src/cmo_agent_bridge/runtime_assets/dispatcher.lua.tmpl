local function unit_loadout_result(unit_guid)
    local unit = read_unit_by_guid(unit_guid, "loadout unit readback failed")
    local ok, loadout = pcall(
        ScenEdit_GetLoadout,
        { unitname = unit_guid, LoadoutID = 0 }
    )
    if not ok or loadout == nil then
        error("ScenEdit_GetLoadout failed: " .. text_or(loadout, "no loadout returned"))
    end
    local weapons = Json.array()
    for _, weapon in ipairs(
        collect_ordered(safe_get(loadout, { "weapons", "Weapons" }))
    ) do
        local guid = nullable_text(
            safe_get(weapon, { "wpn_guid", "WpnGuid", "guid", "GUID" })
        )
        weapons[#weapons + 1] = Json.object({
            guid = guid,
            dbid = integer_or(
                safe_get(weapon, { "wpn_dbid", "WpnDBID", "dbid", "DBID" }),
                0
            ),
            name = text_or(
                safe_get(weapon, { "wpn_name", "WpnName", "name", "Name" }),
                ""
            ),
            type_code = nullable_enum_integer(
                safe_get(weapon, { "wpn_type", "WpnType", "type", "Type" })
            ),
            current = integer_or(
                safe_get(weapon, { "wpn_current", "WpnCurrent", "current", "Current" }),
                0
            ),
            max_capacity = integer_or(
                safe_get(weapon, { "wpn_maxcap", "WpnMaxCap", "maxcap", "MaxCap" }),
                0
            ),
            default = integer_or(
                safe_get(weapon, { "wpn_default", "WpnDefault", "default", "Default" }),
                0
            ),
        })
    end
    local loadout_dbid = integer_or(
        safe_get(loadout, { "dbid", "DBID" }),
        integer_or(safe_get(unit, { "loadoutdbid", "LoadoutDBID" }), 0)
    )
    if loadout_dbid <= 0 then
        error("current loadout DBID could not be read")
    end
    return Json.object({
        unit_guid = text_or(
            safe_get(unit, { "guid", "Guid", "GUID" }),
            unit_guid
        ),
        loadout_dbid = loadout_dbid,
        name = text_or(safe_get(loadout, { "name", "Name" }), ""),
        ready_time_seconds = nullable_number(
            safe_get(unit, { "readytime_v", "ReadyTime_v", "ReadyTimeV" })
        ),
        weapons = weapons,
    })
end

