-- CMO Agent Bridge minimal trusted-local runtime.
-- This file is rendered by the Python host; template values are release-bound constants.

local BRIDGE = {
    protocol = "@@PROTOCOL@@",
    runtime_version = "@@RUNTIME_VERSION@@",
    runtime_tag = "@@RUNTIME_TAG@@",
    runtime_asset_sha256 = "@@RUNTIME_ASSET_SHA256@@",
    release_id = "@@RELEASE_ID@@",
    operation_manifest_sha256 = "@@OPERATION_MANIFEST_SHA256@@",
}

local Json = {}
Json.null = setmetatable({}, { __tostring = function() return "null" end })
local ARRAY_MT = { __json_type = "array" }
local OBJECT_MT = { __json_type = "object" }

function Json.array(value)
    return setmetatable(value or {}, ARRAY_MT)
end

function Json.object(value)
    return setmetatable(value or {}, OBJECT_MT)
end

local ESCAPES = {
    ['"'] = '\\"',
    ['\\'] = '\\\\',
    ['\b'] = '\\b',
    ['\f'] = '\\f',
    ['\n'] = '\\n',
    ['\r'] = '\\r',
    ['\t'] = '\\t',
}

local function encode_string(value)
    return '"' .. value:gsub('[%z\1-\31\\"]', function(character)
        return ESCAPES[character] or string.format('\\u%04x', string.byte(character))
    end) .. '"'
end

local function encode_value(value, stack)
    if value == Json.null then
        return "null"
    end
    local kind = type(value)
    if kind == "nil" then
        return "null"
    elseif kind == "boolean" then
        return value and "true" or "false"
    elseif kind == "number" then
        if value ~= value or value == math.huge or value == -math.huge then
            error("cannot encode a non-finite JSON number")
        end
        return tostring(value)
    elseif kind == "string" then
        return encode_string(value)
    elseif kind ~= "table" then
        error("cannot encode JSON value of type " .. kind)
    end

    if stack[value] then
        error("cannot encode a cyclic JSON table")
    end
    stack[value] = true
    local output = {}
    local marker = getmetatable(value)
    if marker == ARRAY_MT then
        for index = 1, #value do
            output[#output + 1] = encode_value(value[index], stack)
        end
        stack[value] = nil
        return "[" .. table.concat(output, ",") .. "]"
    end

    local keys = {}
    for key, _ in pairs(value) do
        if type(key) ~= "string" then
            error("JSON object keys must be strings")
        end
        keys[#keys + 1] = key
    end
    table.sort(keys)
    for _, key in ipairs(keys) do
        output[#output + 1] = encode_string(key) .. ":" .. encode_value(value[key], stack)
    end
    stack[value] = nil
    return "{" .. table.concat(output, ",") .. "}"
end

function Json.encode(value)
    return encode_value(value, {})
end

local function utf8_character(codepoint)
    if codepoint <= 0x7f then
        return string.char(codepoint)
    elseif codepoint <= 0x7ff then
        return string.char(
            0xc0 + math.floor(codepoint / 0x40),
            0x80 + (codepoint % 0x40)
        )
    elseif codepoint <= 0xffff then
        return string.char(
            0xe0 + math.floor(codepoint / 0x1000),
            0x80 + (math.floor(codepoint / 0x40) % 0x40),
            0x80 + (codepoint % 0x40)
        )
    elseif codepoint <= 0x10ffff then
        return string.char(
            0xf0 + math.floor(codepoint / 0x40000),
            0x80 + (math.floor(codepoint / 0x1000) % 0x40),
            0x80 + (math.floor(codepoint / 0x40) % 0x40),
            0x80 + (codepoint % 0x40)
        )
    end
    error("invalid Unicode codepoint")
end

local function decode_error(position, message)
    error("invalid JSON at byte " .. tostring(position) .. ": " .. message)
end

local function skip_space(text, position)
    while position <= #text do
        local byte = string.byte(text, position)
        if byte ~= 0x20 and byte ~= 0x09 and byte ~= 0x0a and byte ~= 0x0d then
            break
        end
        position = position + 1
    end
    return position
end

local parse_value

local function parse_string(text, position)
    local output = {}
    position = position + 1
    local segment_start = position
    while position <= #text do
        local byte = string.byte(text, position)
        if byte == 0x22 then
            output[#output + 1] = string.sub(text, segment_start, position - 1)
            return table.concat(output), position + 1
        elseif byte == 0x5c then
            output[#output + 1] = string.sub(text, segment_start, position - 1)
            local escape = string.sub(text, position + 1, position + 1)
            local simple = {
                ['"'] = '"',
                ['\\'] = '\\',
                ['/'] = '/',
                ['b'] = '\b',
                ['f'] = '\f',
                ['n'] = '\n',
                ['r'] = '\r',
                ['t'] = '\t',
            }
            if simple[escape] ~= nil then
                output[#output + 1] = simple[escape]
                position = position + 2
            elseif escape == "u" then
                local hex = string.sub(text, position + 2, position + 5)
                local codepoint = tonumber(hex, 16)
                if codepoint == nil or #hex ~= 4 then
                    decode_error(position, "invalid Unicode escape")
                end
                position = position + 6
                if codepoint >= 0xd800 and codepoint <= 0xdbff then
                    if string.sub(text, position, position + 1) ~= "\\u" then
                        decode_error(position, "missing low Unicode surrogate")
                    end
                    local low_hex = string.sub(text, position + 2, position + 5)
                    local low = tonumber(low_hex, 16)
                    if low == nil or low < 0xdc00 or low > 0xdfff then
                        decode_error(position, "invalid low Unicode surrogate")
                    end
                    codepoint = 0x10000 + ((codepoint - 0xd800) * 0x400) + (low - 0xdc00)
                    position = position + 6
                elseif codepoint >= 0xdc00 and codepoint <= 0xdfff then
                    decode_error(position, "unexpected low Unicode surrogate")
                end
                output[#output + 1] = utf8_character(codepoint)
            else
                decode_error(position, "invalid string escape")
            end
            segment_start = position
        elseif byte < 0x20 then
            decode_error(position, "unescaped control character")
        else
            position = position + 1
        end
    end
    decode_error(position, "unterminated string")
end

local function parse_array(text, position)
    local result = Json.array()
    position = skip_space(text, position + 1)
    if string.sub(text, position, position) == "]" then
        return result, position + 1
    end
    while true do
        local item
        item, position = parse_value(text, position)
        result[#result + 1] = item
        position = skip_space(text, position)
        local character = string.sub(text, position, position)
        if character == "]" then
            return result, position + 1
        elseif character ~= "," then
            decode_error(position, "expected ',' or ']'")
        end
        position = skip_space(text, position + 1)
    end
end

local function parse_object(text, position)
    local result = Json.object()
    position = skip_space(text, position + 1)
    if string.sub(text, position, position) == "}" then
        return result, position + 1
    end
    while true do
        if string.sub(text, position, position) ~= '"' then
            decode_error(position, "expected object key")
        end
        local key
        key, position = parse_string(text, position)
        position = skip_space(text, position)
        if string.sub(text, position, position) ~= ":" then
            decode_error(position, "expected ':'")
        end
        position = skip_space(text, position + 1)
        result[key], position = parse_value(text, position)
        position = skip_space(text, position)
        local character = string.sub(text, position, position)
        if character == "}" then
            return result, position + 1
        elseif character ~= "," then
            decode_error(position, "expected ',' or '}'")
        end
        position = skip_space(text, position + 1)
    end
end

local function parse_number(text, position)
    local token = string.match(text, "^%-?%d+%.?%d*[eE]?[+%-]?%d*", position)
    local value = token and tonumber(token) or nil
    if value == nil then
        decode_error(position, "invalid number")
    end
    return value, position + #token
end

parse_value = function(text, position)
    position = skip_space(text, position)
    local character = string.sub(text, position, position)
    if character == '"' then
        return parse_string(text, position)
    elseif character == "{" then
        return parse_object(text, position)
    elseif character == "[" then
        return parse_array(text, position)
    elseif character == "-" or string.match(character, "%d") then
        return parse_number(text, position)
    elseif string.sub(text, position, position + 3) == "true" then
        return true, position + 4
    elseif string.sub(text, position, position + 4) == "false" then
        return false, position + 5
    elseif string.sub(text, position, position + 3) == "null" then
        return Json.null, position + 4
    end
    decode_error(position, "unexpected token")
end

function Json.decode(text)
    if type(text) ~= "string" then
        error("JSON input must be a string")
    end
    local value, position = parse_value(text, 1)
    position = skip_space(text, position)
    if position ~= #text + 1 then
        decode_error(position, "trailing data")
    end
    return value
end

local function safe_get(value, names)
    if value == nil then
        return nil
    end
    for _, name in ipairs(names) do
        local ok, item = pcall(function() return value[name] end)
        if ok and item ~= nil then
            return item
        end
    end
    return nil
end

local function collect(value)
    local result = {}
    if value == nil then
        return result
    end
    pcall(function()
        for _, item in pairs(value) do
            result[#result + 1] = item
        end
    end)
    return result
end

local function collect_ordered(value)
    local indexed = {}
    local unindexed = {}
    if value == nil then
        return unindexed
    end
    pcall(function()
        for key, item in pairs(value) do
            local numeric_key = tonumber(key)
            if numeric_key ~= nil and numeric_key == math.floor(numeric_key) then
                indexed[#indexed + 1] = { order = numeric_key, value = item }
            else
                unindexed[#unindexed + 1] = { order = tostring(key), value = item }
            end
        end
    end)
    table.sort(indexed, function(left, right) return left.order < right.order end)
    table.sort(unindexed, function(left, right) return left.order < right.order end)
    local result = {}
    for _, entry in ipairs(indexed) do
        result[#result + 1] = entry.value
    end
    for _, entry in ipairs(unindexed) do
        result[#result + 1] = entry.value
    end
    return result
end

local function collection_count(value)
    return #collect(value)
end

local function text_or(value, fallback)
    if value == nil or value == Json.null then
        return fallback
    end
    return tostring(value)
end

local function nullable_text(value)
    if value == nil or value == Json.null then
        return Json.null
    end
    local converted = tostring(value)
    if converted == "" then
        return Json.null
    end
    return converted
end

local function number_or(value, fallback)
    if value == nil or value == Json.null then
        return fallback
    end
    local converted = tonumber(value)
    if converted == nil or converted ~= converted or converted == math.huge or converted == -math.huge then
        return fallback
    end
    return converted
end

local function integer_or(value, fallback)
    return math.floor(number_or(value, fallback))
end

local function boolean_or(value, fallback)
    if type(value) == "boolean" then
        return value
    elseif type(value) == "number" then
        return value ~= 0
    elseif type(value) == "string" then
        local lowered = string.lower(value)
        if lowered == "true" or lowered == "yes" or lowered == "1" then
            return true
        elseif lowered == "false" or lowered == "no" or lowered == "0" then
            return false
        end
    end
    return fallback
end

local function stable_uuid(value)
    local hashes = { 2166136261, 2246822519, 3266489917, 668265263 }
    for index = 1, #value do
        local byte = string.byte(value, index)
        for slot = 1, 4 do
            hashes[slot] = (hashes[slot] * 131 + byte + slot * 17) % 4294967296
        end
    end
    local raw = string.format("%08x%08x%08x%08x", hashes[1], hashes[2], hashes[3], hashes[4])
    return string.sub(raw, 1, 8)
        .. "-" .. string.sub(raw, 9, 12)
        .. "-4" .. string.sub(raw, 14, 16)
        .. "-8" .. string.sub(raw, 18, 20)
        .. "-" .. string.sub(raw, 21, 32)
end

local function normalized_uuid(value)
    local text = text_or(value, "")
    text = string.lower(string.gsub(string.gsub(text, "^{", ""), "}$", ""))
    local compact = string.gsub(text, "%-", "")
    if #compact == 32 and string.match(compact, "^%x+$") then
        return string.sub(compact, 1, 8)
            .. "-" .. string.sub(compact, 9, 12)
            .. "-" .. string.sub(compact, 13, 16)
            .. "-" .. string.sub(compact, 17, 20)
            .. "-" .. string.sub(compact, 21, 32)
    end
    return stable_uuid(text ~= "" and text or "cmo-agent-bridge-scenario")
end

local function scenario_context()
    local ok, scenario = pcall(VP_GetScenario)
    if not ok or scenario == nil then
        error("VP_GetScenario failed: " .. text_or(scenario, "no scenario returned"))
    end
    local guid = safe_get(scenario, { "guid", "Guid", "GUID" })
    local lineage_seed = text_or(guid, "")
    if lineage_seed == "" then
        lineage_seed = text_or(safe_get(scenario, { "FileName", "filename", "file_name" }), "")
            .. "|" .. text_or(safe_get(scenario, { "Title", "title" }), "")
    end
    local current_time = safe_get(
        scenario,
        { "CurrentTime", "currenttime", "current_time" }
    )
    return scenario, normalized_uuid(lineage_seed), text_or(current_time, "unknown")
end

local function status_result(lineage_id, activation_id)
    local ok, raw_build = pcall(GetBuildNumber)
    local build_text = ok and text_or(raw_build, "") or ""
    local build = tonumber(string.match(build_text, "(%d+)")) or 1
    return Json.object({
        protocol = BRIDGE.protocol,
        runtime_version = BRIDGE.runtime_version,
        runtime_tag = BRIDGE.runtime_tag,
        runtime_asset_sha256 = BRIDGE.runtime_asset_sha256,
        release_id = BRIDGE.release_id,
        build = math.max(1, math.floor(build)),
        manifest_sha256 = BRIDGE.operation_manifest_sha256,
        lineage_id = lineage_id,
        activation_id = activation_id,
        installed_event_names = Json.array(),
        installed_action_names = Json.array(),
        installed_trigger_names = Json.array(),
        pending_request_id = Json.null,
        quarantined = false,
        paused_capability = Json.null,
        poll_interval_seconds = 1,
        safe_payload_bytes = 65536,
        verified_ledger_entries = 1,
        effective_ledger_capacity = 1,
    })
end

local function scenario_result(scenario, lineage_id)
    local current = safe_get(scenario, { "CurrentTime", "currenttime", "current_time" })
    local start = safe_get(scenario, { "StartTime", "starttime", "start_time" })
    local duration = safe_get(scenario, { "Duration", "duration" })
    local current_call_ok, current_call = pcall(ScenEdit_CurrentTime)
    if not current_call_ok then
        current_call = nil
    end
    local current_seconds = safe_get(
        scenario,
        {
            "CurrentTimeNum",
            "CurrentTimeSeconds",
            "currenttimenum",
            "currenttimeseconds",
            "current_time_seconds",
        }
    )
    local start_seconds = safe_get(
        scenario,
        {
            "StartTimeNum",
            "StartTimeSeconds",
            "starttimenum",
            "starttimeseconds",
            "start_time_seconds",
        }
    )
    local duration_seconds = safe_get(
        scenario,
        {
            "DurationNum",
            "DurationSeconds",
            "durationnum",
            "durationseconds",
            "duration_seconds",
        }
    )
    return Json.object({
        guid = text_or(safe_get(scenario, { "guid", "Guid", "GUID" }), lineage_id),
        title = text_or(safe_get(scenario, { "Title", "title" }), ""),
        file_name = text_or(
            safe_get(scenario, { "FileName", "filename", "file_name" }),
            ""
        ),
        file_name_path = text_or(
            safe_get(scenario, { "FileNamePath", "filenamepath", "file_name_path" }),
            ""
        ),
        current_time = text_or(current, ""),
        current_time_seconds = number_or(
            current_seconds,
            number_or(current_call, number_or(current, 0))
        ),
        start_time = text_or(start, ""),
        start_time_seconds = number_or(start_seconds, number_or(start, 0)),
        duration = text_or(duration, ""),
        duration_seconds = number_or(duration_seconds, number_or(duration, 0)),
        complexity = integer_or(safe_get(scenario, { "Complexity", "complexity" }), 0),
        difficulty = integer_or(safe_get(scenario, { "Difficulty", "difficulty" }), 0),
        setting = text_or(
            safe_get(scenario, { "ScenSetting", "Setting", "scensetting", "setting" }),
            ""
        ),
        database = text_or(
            safe_get(scenario, { "DBUsed", "Database", "database", "dbused" }),
            ""
        ),
        save_version = text_or(
            safe_get(scenario, { "SaveVersion", "saveversion", "save_version" }),
            ""
        ),
        started = boolean_or(
            safe_get(scenario, { "HasStarted", "hasstarted", "started" }),
            false
        ),
        player_side_guid = nullable_text(
            safe_get(
                scenario,
                { "PlayerSide", "playerside", "playerSide", "player_side" }
            )
        ),
        time_compression = number_or(
            safe_get(scenario, { "TimeCompression", "timecompression", "time_compression" }),
            1
        ),
        campaign_score = integer_or(
            safe_get(scenario, { "CampaignScore", "campaignscore", "campaign_score" }),
            0
        ),
    })
end

local function scenario_time_compression_set_result(arguments)
    local code = integer_or(arguments.code, -1)
    local expected_by_code = {
        [0] = 1,
        [1] = 2,
        [2] = 5,
        [3] = 15,
        [4] = 30,
        [5] = 150,
    }
    local expected = expected_by_code[code]
    if expected == nil then
        error("time compression code must be between 0 and 5")
    end
    local ok, failure = pcall(VP_SetTimeCompression, code)
    if not ok then
        error("VP_SetTimeCompression failed: " .. text_or(failure, "unknown error"))
    end
    local read_ok, scenario = pcall(VP_GetScenario)
    if not read_ok or scenario == nil then
        error(
            "time compression readback failed: "
                .. text_or(scenario, "no scenario returned")
        )
    end
    local observed = math.floor(
        number_or(
            safe_get(
                scenario,
                { "TimeCompression", "timecompression", "time_compression" }
            ),
            -1
        )
    )
    if observed < 0 or observed ~= expected then
        error("time compression did not match readback")
    end
    return Json.object({
        code = code,
        observed_time_compression = observed,
        accepted = true,
    })
end

local SIDE_FIELDS = {
    "name",
    "awareness",
    "proficiency",
    "computer_controlled_only",
    "unit_count",
    "contact_count",
    "mission_count",
}

local function side_full_result(side)
    return {
        guid = text_or(safe_get(side, { "guid", "Guid", "GUID" }), "unknown-side"),
        name = text_or(safe_get(side, { "name", "Name" }), ""),
        awareness = text_or(safe_get(side, { "awareness", "Awareness" }), ""),
        proficiency = text_or(safe_get(side, { "proficiency", "Proficiency" }), ""),
        computer_controlled_only = boolean_or(
            safe_get(
                side,
                {
                    "iscomputeronly",
                    "IsComputerOnly",
                    "computercontrolledonly",
                    "ComputerControlledOnly",
                }
            ),
            false
        ),
        unit_count = collection_count(safe_get(side, { "units", "Units" })),
        contact_count = collection_count(safe_get(side, { "contacts", "Contacts" })),
        mission_count = collection_count(safe_get(side, { "missions", "Missions" })),
    }
end

local function side_list_result(arguments)
    local ok, wrappers = pcall(VP_GetSides)
    if not ok or wrappers == nil then
        error("VP_GetSides failed: " .. text_or(wrappers, "no sides returned"))
    end
    local sides = collect(wrappers)
    local normalized = {}
    for _, side in ipairs(sides) do
        normalized[#normalized + 1] = side_full_result(side)
    end
    table.sort(normalized, function(left, right)
        if left.guid == right.guid then
            return left.name < right.name
        end
        return left.guid < right.guid
    end)

    local cursor = arguments.cursor
    local offset = 0
    if cursor ~= nil and cursor ~= Json.null then
        if type(cursor) ~= "string" or string.match(cursor, "^%d+$") == nil then
            error("side.list cursor must be a non-negative decimal offset")
        end
        offset = tonumber(cursor) or 0
    end
    local page_size = math.max(1, math.floor(number_or(arguments.page_size, 100)))
    local final_index = math.min(#normalized, offset + page_size)
    local wanted = nil
    if arguments.fields ~= nil and arguments.fields ~= Json.null then
        wanted = {}
        for _, field in ipairs(arguments.fields) do
            wanted[field] = true
        end
    end

    local items = Json.array()
    for index = offset + 1, final_index do
        local source = normalized[index]
        local item = Json.object({ guid = source.guid })
        for _, field in ipairs(SIDE_FIELDS) do
            if wanted == nil or wanted[field] then
                item[field] = source[field]
            end
        end
        items[#items + 1] = item
    end
    local next_cursor = Json.null
    if final_index < #normalized then
        next_cursor = tostring(final_index)
    end
    return Json.object({ items = items, next_cursor = next_cursor })
end

local function side_posture_get_result(arguments)
    local side_a_guid = tostring(arguments.side_a_guid)
    local side_b_guid = tostring(arguments.side_b_guid)
    local ok, posture = pcall(
        ScenEdit_GetSidePosture,
        side_a_guid,
        side_b_guid
    )
    if not ok then
        error("ScenEdit_GetSidePosture failed: " .. text_or(posture, "unknown error"))
    end
    return Json.object({
        side_a_guid = side_a_guid,
        side_b_guid = side_b_guid,
        posture = text_or(posture, ""),
    })
end

local function nullable_number(value)
    if value == nil or value == Json.null then
        return Json.null
    end
    local converted = tonumber(value)
    if converted == nil or converted ~= converted or converted == math.huge or converted == -math.huge then
        return Json.null
    end
    return converted
end

local function nullable_integer(value)
    local converted = nullable_number(value)
    if converted == Json.null then
        return Json.null
    end
    return math.floor(converted)
end

local function nullable_enum_integer(value)
    local numeric = nullable_integer(value)
    if numeric == Json.null then
        numeric = nullable_integer(safe_get(value, { "value__", "Value", "value" }))
    end
    return numeric
end

local function nullable_boolean(value)
    if value == nil or value == Json.null then
        return Json.null
    end
    return boolean_or(value, false)
end

local function nullable_scalar(value)
    if value == nil or value == Json.null then
        return Json.null
    end
    local kind = type(value)
    if kind == "string" or kind == "number" or kind == "boolean" then
        return value
    end
    return tostring(value)
end

local function object_guid(value)
    return text_or(safe_get(value, { "guid", "Guid", "GUID", "objectid", "ObjectID" }), "")
end

local function object_name(value)
    if type(value) == "string" or type(value) == "number" then
        return tostring(value)
    end
    return text_or(safe_get(value, { "name", "Name" }), "")
end

local function normalized_object_reference(value)
    if value == nil or value == Json.null then
        return Json.null
    end
    local guid = object_guid(value)
    if guid ~= "" then
        return guid
    end
    local name = object_name(value)
    if name ~= "" then
        return name
    end
    return Json.null
end

local function require_confirmation_proof(arguments)
    local proof = arguments.confirmation_proof
    if type(proof) ~= "string"
        or #proof ~= 64
        or string.match(proof, "^[0-9a-f]+$") == nil
    then
        error("a valid confirmation proof is required")
    end
end

local function lower_text(value)
    return string.lower(text_or(value, ""))
end

local function resolve_side(arguments)
    local wanted_guid = arguments.side_guid
    local wanted_name = arguments.side_name
    local ok, wrappers = pcall(VP_GetSides)
    if not ok or wrappers == nil then
        error("VP_GetSides failed: " .. text_or(wrappers, "no sides returned"))
    end
    for _, side in ipairs(collect(wrappers)) do
        local guid = object_guid(side)
        local name = object_name(side)
        if wanted_guid ~= nil and wanted_guid ~= Json.null and guid == tostring(wanted_guid) then
            return side
        end
        if wanted_name ~= nil
            and wanted_name ~= Json.null
            and string.lower(name) == string.lower(tostring(wanted_name))
        then
            return side
        end
    end
    error("side was not found")
end

local function side_api_selector(arguments, side)
    if arguments.side_guid ~= nil and arguments.side_guid ~= Json.null then
        return tostring(arguments.side_guid)
    end
    if arguments.side_name ~= nil and arguments.side_name ~= Json.null then
        return tostring(arguments.side_name)
    end
    local guid = object_guid(side)
    if guid ~= "" then
        return guid
    end
    return object_name(side)
end

local function page_and_project(normalized, arguments, fields, operation)
    table.sort(normalized, function(left, right)
        if left.guid == right.guid then
            return left.name < right.name
        end
        return left.guid < right.guid
    end)

    local cursor = arguments.cursor
    local offset = 0
    if cursor ~= nil and cursor ~= Json.null then
        if type(cursor) ~= "string" or string.match(cursor, "^%d+$") == nil then
            error(operation .. " cursor must be a non-negative decimal offset")
        end
        offset = tonumber(cursor) or 0
    end
    local page_size = math.max(1, math.floor(number_or(arguments.page_size, 100)))
    local final_index = math.min(#normalized, offset + page_size)
    local wanted = nil
    if arguments.fields ~= nil and arguments.fields ~= Json.null then
        wanted = {}
        for _, field in ipairs(arguments.fields) do
            wanted[field] = true
        end
    end

    local items = Json.array()
    for index = offset + 1, final_index do
        local source = normalized[index]
        local item = Json.object({ guid = source.guid })
        for _, field in ipairs(fields) do
            if wanted == nil or wanted[field] then
                item[field] = source[field]
            end
        end
        items[#items + 1] = item
    end
    local next_cursor = Json.null
    if final_index < #normalized then
        next_cursor = tostring(final_index)
    end
    return Json.object({ items = items, next_cursor = next_cursor })
end

local function collect_identifiers(value)
    local result = Json.array()
    for _, item in ipairs(collect(value)) do
        local identifier
        if type(item) == "string" or type(item) == "number" then
            identifier = tostring(item)
        else
            identifier = object_guid(item)
            if identifier == "" then
                identifier = object_name(item)
            end
        end
        if identifier ~= "" then
            result[#result + 1] = identifier
        end
    end
    table.sort(result)
    return result
end

local function collect_reference_point_guids(side, value)
    local guid_by_name = {}
    local guid_by_lower_name = {}
    local known_guids = {}
    for _, reference_point in ipairs(
        collect(safe_get(side, { "rps", "RPs", "referencepoints", "ReferencePoints" }))
    ) do
        local guid = object_guid(reference_point)
        local name = object_name(reference_point)
        if guid ~= "" then
            known_guids[guid] = true
            if name ~= "" then
                guid_by_name[name] = guid
                guid_by_lower_name[string.lower(name)] = guid
            end
        end
    end

    local result = Json.array()
    for _, item in ipairs(collect_ordered(value)) do
        local guid = ""
        if type(item) == "string" or type(item) == "number" then
            local identifier = tostring(item)
            guid = guid_by_name[identifier]
                or guid_by_lower_name[string.lower(identifier)]
                or (known_guids[identifier] and identifier or "")
        else
            guid = object_guid(item)
            if guid == "" then
                local name = object_name(item)
                guid = guid_by_name[name] or guid_by_lower_name[string.lower(name)] or ""
            end
        end
        if guid ~= "" then
            result[#result + 1] = guid
        end
    end
    return result
end

local function ordered_strings(value)
    local result = {}
    for _, item in ipairs(collect_ordered(value)) do
        result[#result + 1] = tostring(item)
    end
    return result
end

local function contains_identifier(values, wanted)
    local normalized = string.lower(tostring(wanted))
    for _, value in ipairs(values) do
        if string.lower(tostring(value)) == normalized then
            return true
        end
    end
    return false
end

local function same_identifiers_in_order(left, right)
    if #left ~= #right then
        return false
    end
    for index = 1, #left do
        if string.lower(tostring(left[index])) ~= string.lower(tostring(right[index])) then
            return false
        end
    end
    return true
end

local function same_identifier_sets(left, right)
    if #left ~= #right then
        return false
    end
    for _, value in ipairs(left) do
        if not contains_identifier(right, value) then
            return false
        end
    end
    return true
end

local REFERENCE_POINT_FIELDS = {
    "name",
    "side_guid",
    "latitude",
    "longitude",
    "relative_to_type",
    "relative_to_guid",
    "relative_bearing_deg",
    "relative_distance_nm",
    "bearing_type",
}

local function normalized_reference_point_bearing_type(value)
    local numeric = nullable_enum_integer(value)
    if numeric == 0 then
        return "fixed"
    elseif numeric == 1 then
        return "rotating"
    end
    local key = string.lower(string.gsub(text_or(value, ""), "[^%w]", ""))
    if key == "fixed" or string.find(key, "fixed", 1, true) ~= nil then
        return "fixed"
    elseif key == "rotating" or string.find(key, "rotat", 1, true) ~= nil then
        return "rotating"
    end
    return Json.null
end

local function reference_point_relative_values(reference_point)
    local unit_anchor = safe_get(
        reference_point,
        { "relativeto", "RelativeTo", "relativeTo" }
    )
    local contact_anchor = safe_get(
        reference_point,
        {
            "relativeto_contact",
            "RelativeToContact",
            "relativeToContact",
        }
    )
    local reference_point_anchor = safe_get(
        reference_point,
        {
            "relativeto_rp",
            "RelativeToRP",
            "relativeToRP",
            "RelativeToReferencePoint",
        }
    )
    local anchor = unit_anchor
    local anchor_type = nil
    if contact_anchor ~= nil and contact_anchor ~= Json.null then
        anchor = contact_anchor
        anchor_type = "contact"
    elseif reference_point_anchor ~= nil and reference_point_anchor ~= Json.null then
        anchor = reference_point_anchor
        anchor_type = "reference_point"
    elseif unit_anchor ~= nil and unit_anchor ~= Json.null then
        anchor_type = "unit"
    end
    if anchor == nil or anchor == Json.null then
        return nil
    end

    local raw_type = safe_get(
        reference_point,
        {
            "relativeto_type",
            "RelativeToType",
            "relativeToType",
            "relative_type",
        }
    )
    local type_key = string.lower(string.gsub(text_or(raw_type, ""), "[^%w]", ""))
    if string.find(type_key, "contact", 1, true) ~= nil then
        anchor_type = "contact"
    elseif string.find(type_key, "referencepoint", 1, true) ~= nil
        or type_key == "rp"
    then
        anchor_type = "reference_point"
    elseif string.find(type_key, "unit", 1, true) ~= nil then
        anchor_type = "unit"
    elseif anchor_type == nil then
        anchor_type = "unknown"
    end

    local anchor_guid = normalized_object_reference(anchor)
    if anchor_guid == Json.null then
        anchor_guid = nullable_text(anchor)
    end
    return {
        relative_to_type = anchor_type,
        relative_to_guid = anchor_guid,
        relative_bearing_deg = nullable_number(
            safe_get(
                reference_point,
                {
                    "bearing",
                    "Bearing",
                    "relativebearing",
                    "RelativeBearing",
                    "relativeBearing",
                }
            )
        ),
        relative_distance_nm = nullable_number(
            safe_get(
                reference_point,
                {
                    "distance",
                    "Distance",
                    "relativedistance",
                    "RelativeDistance",
                    "relativeDistance",
                }
            )
        ),
        bearing_type = normalized_reference_point_bearing_type(
            safe_get(
                reference_point,
                { "bearingtype", "BearingType", "bearingType" }
            )
        ),
    }
end

local function reference_point_full_result(reference_point, side)
    local guid = object_guid(reference_point)
    local latitude = nullable_number(
        safe_get(reference_point, { "latitude", "Latitude", "lat", "Lat" })
    )
    local longitude = nullable_number(
        safe_get(reference_point, { "longitude", "Longitude", "lon", "Lon" })
    )
    if guid == "" then
        error("reference point GUID could not be read back")
    end
    if latitude == Json.null or longitude == Json.null then
        error("reference point coordinates could not be read back")
    end
    local side_guid = object_guid(side)
    if side_guid == "" then
        error("reference point side GUID could not be read back")
    end
    local result = {
        guid = guid,
        name = object_name(reference_point),
        side_guid = side_guid,
        latitude = latitude,
        longitude = longitude,
    }
    local relative = reference_point_relative_values(reference_point)
    if relative ~= nil then
        result.relative_to_type = relative.relative_to_type
        result.relative_to_guid = relative.relative_to_guid
        result.relative_bearing_deg = relative.relative_bearing_deg
        result.relative_distance_nm = relative.relative_distance_nm
        result.bearing_type = relative.bearing_type
    end
    return result
end

local function reference_point_list_result(arguments)
    local side = resolve_side(arguments)
    local normalized = {}
    for _, reference_point in ipairs(
        collect(safe_get(side, { "rps", "RPs", "referencepoints", "ReferencePoints" }))
    ) do
        normalized[#normalized + 1] = reference_point_full_result(reference_point, side)
    end
    return page_and_project(
        normalized,
        arguments,
        REFERENCE_POINT_FIELDS,
        "reference_point.list"
    )
end

local function reference_point_readback(side, selector, fallback)
    local ok, reference_points = pcall(
        ScenEdit_GetReferencePoints,
        { side = selector, area = { fallback } }
    )
    if not ok or reference_points == nil then
        error(
            "ScenEdit_GetReferencePoints failed: "
                .. text_or(reference_points, "no reference points returned")
        )
    end
    for _, reference_point in ipairs(collect_ordered(reference_points)) do
        if lower_text(object_guid(reference_point)) == lower_text(fallback) then
            return Json.object(reference_point_full_result(reference_point, side))
        end
    end
    error("requested reference point was not present in readback")
end

local function reference_point_add_result(arguments)
    local side = resolve_side(arguments)
    local selector = side_api_selector(arguments, side)
    local descriptor = {
        side = selector,
        name = tostring(arguments.name),
    }
    if arguments.latitude ~= nil and arguments.latitude ~= Json.null then
        descriptor.latitude = number_or(arguments.latitude, 0)
        descriptor.longitude = number_or(arguments.longitude, 0)
    else
        local anchor_type = tostring(arguments.relative_to_type)
        if anchor_type == "contact" then
            descriptor.relativeto_contact = tostring(arguments.relative_to_guid)
        elseif anchor_type == "reference_point" then
            descriptor.relativeto_rp = tostring(arguments.relative_to_guid)
        else
            descriptor.relativeto = tostring(arguments.relative_to_guid)
        end
        descriptor.bearing = number_or(arguments.relative_bearing_deg, 0)
        descriptor.distance = number_or(arguments.relative_distance_nm, 0)
        descriptor.bearingtype = arguments.bearing_type == "fixed" and 0 or 1
    end
    local ok, added = pcall(
        ScenEdit_AddReferencePoint,
        descriptor
    )
    if not ok or added == nil or added == false then
        error(
            "ScenEdit_AddReferencePoint failed: "
                .. text_or(added, "no reference point returned")
        )
    end
    local guid = object_guid(added)
    if guid == "" then
        error("added reference point GUID could not be read back")
    end
    local read_ok, result = pcall(reference_point_readback, side, selector, guid)
    if not read_ok then
        pcall(
            ScenEdit_DeleteReferencePoint,
            { side = selector, guid = guid }
        )
        error(text_or(result, "added reference point readback failed"))
    end
    return result
end

local function reference_point_update_result(arguments)
    local side = resolve_side(arguments)
    local selector = side_api_selector(arguments, side)
    local reference_point_guid = tostring(arguments.reference_point_guid)
    local descriptor = { side = selector, guid = reference_point_guid }
    if arguments.name ~= nil and arguments.name ~= Json.null then
        descriptor.newname = tostring(arguments.name)
    end
    if arguments.latitude ~= nil and arguments.latitude ~= Json.null then
        descriptor.latitude = number_or(arguments.latitude, 0)
    end
    if arguments.longitude ~= nil and arguments.longitude ~= Json.null then
        descriptor.longitude = number_or(arguments.longitude, 0)
    end
    if arguments.clear_relative == true then
        descriptor.clear = true
    end
    if arguments.relative_to_guid ~= nil and arguments.relative_to_guid ~= Json.null then
        local anchor_type = tostring(arguments.relative_to_type)
        if anchor_type == "contact" then
            descriptor.relativeto_contact = tostring(arguments.relative_to_guid)
        elseif anchor_type == "reference_point" then
            descriptor.relativeto_rp = tostring(arguments.relative_to_guid)
        else
            descriptor.relativeto = tostring(arguments.relative_to_guid)
        end
    end
    if arguments.relative_bearing_deg ~= nil
        and arguments.relative_bearing_deg ~= Json.null
    then
        descriptor.bearing = number_or(arguments.relative_bearing_deg, 0)
    end
    if arguments.relative_distance_nm ~= nil
        and arguments.relative_distance_nm ~= Json.null
    then
        descriptor.distance = number_or(arguments.relative_distance_nm, 0)
    end
    if arguments.bearing_type ~= nil and arguments.bearing_type ~= Json.null then
        descriptor.bearingtype = arguments.bearing_type == "fixed" and 0 or 1
    elseif arguments.relative_to_guid ~= nil
        and arguments.relative_to_guid ~= Json.null
    then
        descriptor.bearingtype = 1
    end
    local ok, updated = pcall(ScenEdit_SetReferencePoint, descriptor)
    if not ok or updated == nil or updated == false then
        error(
            "ScenEdit_SetReferencePoint failed: "
                .. text_or(updated, "no reference point returned")
        )
    end
    return reference_point_readback(side, selector, reference_point_guid)
end

local UNIT_FIELDS = {
    "dbid",
    "name",
    "side_name",
    "type",
    "subtype",
    "category",
    "class_name",
    "latitude",
    "longitude",
    "altitude",
    "depth",
    "speed",
    "heading",
    "throttle",
    "force_speed",
    "desired_heading",
    "move_to",
    "manual_throttle",
    "manual_speed",
    "manual_altitude",
    "hold_position",
    "hold_fire",
    "sprint_drift",
    "avoid_cavitation",
    "obey_emcon",
    "proficiency",
    "fuel_state",
    "weapon_state",
    "unit_state",
    "operating",
    "mission_guid",
    "mission_name",
    "loadout_dbid",
}

-- Unit wrappers are expensive to hydrate in CMO. Keep each paged request bounded even
-- when the side contains hundreds of units or a selective filter matches very little.
local UNIT_LIST_CANDIDATE_SCAN_LIMIT = 20

local function unit_full_result(unit, fallback_guid)
    local mission = safe_get(unit, { "mission", "Mission" })
    local mission_guid = Json.null
    local mission_name = Json.null
    if mission ~= nil and mission ~= Json.null then
        if type(mission) == "string" then
            mission_name = nullable_text(mission)
        else
            mission_guid = nullable_text(safe_get(mission, { "guid", "Guid", "GUID" }))
            mission_name = nullable_text(safe_get(mission, { "name", "Name" }))
        end
    end
    local loadout_dbid = nullable_integer(
        safe_get(unit, { "loadoutdbid", "LoadoutDBID", "loadout_dbid" })
    )
    if loadout_dbid ~= Json.null and loadout_dbid <= 0 then
        loadout_dbid = Json.null
    end
    return {
        guid = text_or(safe_get(unit, { "guid", "Guid", "GUID" }), fallback_guid),
        dbid = integer_or(safe_get(unit, { "dbid", "DBID" }), 0),
        name = text_or(safe_get(unit, { "name", "Name" }), ""),
        side_name = object_name(safe_get(unit, { "side", "Side" })),
        type = text_or(safe_get(unit, { "type", "Type" }), ""),
        subtype = nullable_text(safe_get(unit, { "subtype", "Subtype" })),
        category = text_or(safe_get(unit, { "category", "Category" }), ""),
        class_name = text_or(
            safe_get(unit, { "classname", "ClassName", "class", "Class" }),
            ""
        ),
        latitude = number_or(safe_get(unit, { "latitude", "Latitude" }), 0),
        longitude = number_or(safe_get(unit, { "longitude", "Longitude" }), 0),
        altitude = number_or(safe_get(unit, { "altitude", "Altitude" }), 0),
        depth = nullable_number(safe_get(unit, { "depth", "Depth" })),
        speed = number_or(safe_get(unit, { "speed", "Speed" }), 0),
        heading = number_or(safe_get(unit, { "heading", "Heading" }), 0),
        throttle = text_or(safe_get(unit, { "throttle", "Throttle" }), ""),
        force_speed = nullable_boolean(
            safe_get(unit, { "forceSpeed", "ForceSpeed", "forcespeed" })
        ),
        desired_heading = nullable_number(
            safe_get(unit, { "desiredHeading", "DesiredHeading", "desiredheading" })
        ),
        move_to = nullable_boolean(safe_get(unit, { "moveto", "moveTo", "MoveTo" })),
        manual_throttle = nullable_scalar(
            safe_get(unit, { "manualThrottle", "manualthrottle", "ManualThrottle" })
        ),
        manual_speed = nullable_scalar(
            safe_get(unit, { "manualSpeed", "manualspeed", "ManualSpeed" })
        ),
        manual_altitude = nullable_scalar(
            safe_get(unit, { "manualAltitude", "manualaltitude", "ManualAltitude" })
        ),
        hold_position = nullable_boolean(
            safe_get(unit, { "holdPosition", "holdposition", "HoldPosition" })
        ),
        hold_fire = nullable_boolean(
            safe_get(unit, { "holdFire", "HoldFire" })
        ),
        sprint_drift = nullable_boolean(
            safe_get(unit, { "sprintDrift", "SprintDrift", "sprintdrift" })
        ),
        avoid_cavitation = nullable_boolean(
            safe_get(unit, { "avoidCavitation", "avoidcavitation", "AvoidCavitation" })
        ),
        obey_emcon = nullable_boolean(
            safe_get(unit, { "obeyEMCON", "ObeyEMCON", "obeyemcon" })
        ),
        proficiency = text_or(safe_get(unit, { "proficiency", "Proficiency" }), ""),
        fuel_state = text_or(safe_get(unit, { "fuelstate", "FuelState" }), ""),
        weapon_state = text_or(safe_get(unit, { "weaponstate", "WeaponState" }), ""),
        unit_state = text_or(safe_get(unit, { "unitstate", "UnitState" }), ""),
        operating = boolean_or(safe_get(unit, { "isOperating", "isoperating" }), false),
        mission_guid = mission_guid,
        mission_name = mission_name,
        loadout_dbid = loadout_dbid,
    }
end

local function unit_list_result(arguments)
    local side = resolve_side(arguments)
    local wanted_name = nil
    if arguments.name_contains ~= nil and arguments.name_contains ~= Json.null then
        wanted_name = lower_text(arguments.name_contains)
    end
    local candidates = {}
    for _, reference in ipairs(collect(safe_get(side, { "units", "Units" }))) do
        local reference_name = object_name(reference)
        if wanted_name == nil
            or reference_name == ""
            or string.find(lower_text(reference_name), wanted_name, 1, true) ~= nil
        then
            candidates[#candidates + 1] = {
                reference = reference,
                guid = object_guid(reference),
                name = reference_name,
            }
        end
    end
    table.sort(candidates, function(left, right)
        if left.guid == right.guid then
            return left.name < right.name
        end
        return left.guid < right.guid
    end)

    local cursor = arguments.cursor
    local offset = 0
    if cursor ~= nil and cursor ~= Json.null then
        if type(cursor) ~= "string" or string.match(cursor, "^%d+$") == nil then
            error("unit.list cursor must be a non-negative decimal offset")
        end
        offset = tonumber(cursor) or 0
    end
    local page_size = math.max(1, math.floor(number_or(arguments.page_size, 100)))
    local final_candidate_index = math.min(
        #candidates,
        offset + UNIT_LIST_CANDIDATE_SCAN_LIMIT
    )
    local wanted_type = nil
    if arguments.unit_type ~= nil and arguments.unit_type ~= Json.null then
        wanted_type = lower_text(arguments.unit_type)
    end
    local normalized = {}
    local candidate_index = offset
    while candidate_index < final_candidate_index and #normalized < page_size do
        candidate_index = candidate_index + 1
        local candidate = candidates[candidate_index]
        local reference = candidate.reference
        local guid = candidate.guid
        local unit = reference
        if guid ~= "" then
            local ok, wrapper = pcall(ScenEdit_GetUnit, { guid = guid })
            if ok and wrapper ~= nil then
                unit = wrapper
            end
        end
        local result = unit_full_result(unit, guid)
        local type_matches = wanted_type == nil or lower_text(result.type) == wanted_type
        local name_matches = wanted_name == nil
            or string.find(lower_text(result.name), wanted_name, 1, true) ~= nil
        if type_matches and name_matches then
            normalized[#normalized + 1] = result
        end
    end

    local wanted = nil
    if arguments.fields ~= nil and arguments.fields ~= Json.null then
        wanted = {}
        for _, field in ipairs(arguments.fields) do
            wanted[field] = true
        end
    end
    local items = Json.array()
    for _, source in ipairs(normalized) do
        local item = Json.object({ guid = source.guid })
        for _, field in ipairs(UNIT_FIELDS) do
            if wanted == nil or wanted[field] then
                item[field] = source[field]
            end
        end
        items[#items + 1] = item
    end
    local next_cursor = Json.null
    if candidate_index < #candidates then
        next_cursor = tostring(candidate_index)
    end
    return Json.object({ items = items, next_cursor = next_cursor })
end

local function unit_get_result(arguments)
    local selector
    if arguments.unit_guid ~= nil and arguments.unit_guid ~= Json.null then
        selector = { guid = tostring(arguments.unit_guid) }
    else
        local side = resolve_side(arguments)
        selector = {
            side = side_api_selector(arguments, side),
            unitname = tostring(arguments.unit_name),
        }
    end
    local ok, unit = pcall(ScenEdit_GetUnit, selector)
    if not ok then
        error("ScenEdit_GetUnit failed: " .. text_or(unit, "unknown error"))
    end
    if unit == nil then
        error("unit was not found")
    end
    return Json.object(unit_full_result(unit, text_or(arguments.unit_guid, "unknown-unit")))
end

local function read_unit_by_guid(unit_guid, label)
    local ok, unit = pcall(ScenEdit_GetUnit, { guid = unit_guid })
    if not ok or unit == nil then
        error(label .. ": " .. text_or(unit, "unit was not found"))
    end
    return unit
