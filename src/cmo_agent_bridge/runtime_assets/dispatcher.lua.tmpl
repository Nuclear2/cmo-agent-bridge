local function doctrine_read(arguments, actual)
    local selector = doctrine_selector(arguments, actual)
    local ok, doctrine = pcall(ScenEdit_GetDoctrine, selector)
    if not ok or doctrine == nil then
        error("ScenEdit_GetDoctrine failed: " .. text_or(doctrine, "no doctrine returned"))
    end
    return doctrine, doctrine_full_result(arguments, actual, doctrine)
end

local function doctrine_get_result(arguments)
    local actual = arguments.actual == true
    local _, result = doctrine_read(arguments, actual)
    return Json.object(result)
end

local function doctrine_set_result(arguments)
    local selector = doctrine_selector(arguments, false)
    selector.actual = nil
    local updates = {}
    local mapping = {
        weapon_control_air = "weapon_control_status_air",
        weapon_control_surface = "weapon_control_status_surface",
        weapon_control_subsurface = "weapon_control_status_subsurface",
        weapon_control_land = "weapon_control_status_land",
        nuclear_use = "use_nuclear_weapons",
        refuel_unrep = "use_refuel_unrep",
        engage_opportunity_targets = "engage_opportunity_targets",
        automatic_evasion = "automatic_evasion",
        ignore_plotted_course = "ignore_plotted_course",
        ignore_emcon_while_under_attack = "ignore_emcon_while_under_attack",
        maintain_standoff = "maintain_standoff",
        use_sams_in_anti_surface_mode = "use_sams_in_anti_surface_mode",
        engaging_ambiguous_targets = "engaging_ambiguous_targets",
        fuel_state_planned = "fuel_state_planned",
        fuel_state_rtb = "fuel_state_rtb",
        weapon_state_planned = "weapon_state_planned",
        weapon_state_rtb = "weapon_state_rtb",
        withdraw_on_attack = "withdraw_on_attack",
        withdraw_on_damage = "withdraw_on_damage",
        withdraw_on_defence = "withdraw_on_defence",
        withdraw_on_fuel = "withdraw_on_fuel",
        bvr_logic = "bvr_logic",
        dipping_sonar = "dipping_sonar",
        use_aip = "use_aip",
        recharge_on_attack = "recharge_on_attack",
        recharge_on_patrol = "recharge_on_patrol",
    }
    for public_name, cmo_name in pairs(mapping) do
        local value = arguments[public_name]
        if value ~= nil and value ~= Json.null then
            updates[cmo_name] = value
        end
    end
    local ok, updated = pcall(ScenEdit_SetDoctrine, selector, updates)
    if not ok or updated == nil or updated == false then
        error("ScenEdit_SetDoctrine failed: " .. text_or(updated, "no doctrine returned"))
    end
    local _, actual = doctrine_read(arguments, true)
    return Json.object({
        scope = actual.scope,
        target_guid = actual.target_guid,
        weapon_control_air = actual.weapon_control_air,
        weapon_control_surface = actual.weapon_control_surface,
        weapon_control_subsurface = actual.weapon_control_subsurface,
        weapon_control_land = actual.weapon_control_land,
        nuclear_use = actual.nuclear_use,
        refuel_unrep = actual.refuel_unrep,
        engage_opportunity_targets = actual.engage_opportunity_targets,
        automatic_evasion = actual.automatic_evasion,
        ignore_plotted_course = actual.ignore_plotted_course,
        ignore_emcon_while_under_attack = actual.ignore_emcon_while_under_attack,
        maintain_standoff = actual.maintain_standoff,
        use_sams_in_anti_surface_mode = actual.use_sams_in_anti_surface_mode,
        engaging_ambiguous_targets = actual.engaging_ambiguous_targets,
        fuel_state_planned = actual.fuel_state_planned,
        fuel_state_rtb = actual.fuel_state_rtb,
        weapon_state_planned = actual.weapon_state_planned,
        weapon_state_rtb = actual.weapon_state_rtb,
        withdraw_on_attack = actual.withdraw_on_attack,
        withdraw_on_damage = actual.withdraw_on_damage,
        withdraw_on_defence = actual.withdraw_on_defence,
        withdraw_on_fuel = actual.withdraw_on_fuel,
        bvr_logic = actual.bvr_logic,
        dipping_sonar = actual.dipping_sonar,
        use_aip = actual.use_aip,
        recharge_on_attack = actual.recharge_on_attack,
        recharge_on_patrol = actual.recharge_on_patrol,
    })
end

local function doctrine_wra_selector(arguments, for_set)
    local selector = {}
    if arguments.scope == "side" then
        selector.side = tostring(arguments.side_guid)
    elseif arguments.scope == "mission" then
        selector.mission = tostring(arguments.mission_guid)
        selector.side = tostring(arguments.side_guid)
    elseif arguments.scope == "unit" then
        selector.guid = tostring(arguments.unit_guid)
        selector.side = tostring(arguments.side_guid)
    else
        error("unsupported WRA doctrine scope")
    end
    if arguments.contact_guid ~= nil and arguments.contact_guid ~= Json.null then
        selector.contact_id = tostring(arguments.contact_guid)
    else
        selector.target_type = arguments.target_type
    end
    if arguments.weapon_dbid ~= nil and arguments.weapon_dbid ~= Json.null then
        if for_set then
            selector.weapon_dbid = integer_or(arguments.weapon_dbid, 0)
        else
            selector.weapon_id = integer_or(arguments.weapon_dbid, 0)
        end
    end
    if not for_set and arguments.full_wra ~= nil and arguments.full_wra ~= Json.null then
        selector.full_wra = arguments.full_wra == true
    end
    return selector
end

local function doctrine_wra_target_guid(arguments)
    if arguments.scope == "side" then
        return tostring(arguments.side_guid)
    elseif arguments.scope == "mission" then
        return tostring(arguments.mission_guid)
    end
    return tostring(arguments.unit_guid)
end

local function doctrine_wra_value(value)
    if value == nil or value == Json.null then
        return Json.null
    end
    if type(value) == "string"
        or type(value) == "number"
    then
        return value
    end
    return tostring(value)
end

local function doctrine_wra_entry(value, key)
    local weapon_dbid = nullable_integer(
        safe_get(value, { "weapon_dbid", "WeaponDBID", "weapon_id", "WeaponID" })
    )
    if weapon_dbid == Json.null and key ~= nil then
        weapon_dbid = nullable_integer(string.match(tostring(key), "(%d+)"))
    end
    if weapon_dbid == Json.null or weapon_dbid <= 0 then
        return nil
    end
    return Json.object({
        weapon_dbid = weapon_dbid,
        weapon_name = text_or(
            safe_get(value, { "weapon_name", "WeaponName", "name", "Name" }),
            ""
        ),
        weapons_per_salvo = doctrine_wra_value(
            safe_get(value, { "qty_salvo", "QtySalvo", "weapons_per_salvo" })
        ),
        shooters_per_salvo = doctrine_wra_value(
            safe_get(value, { "shooter_salvo", "ShooterSalvo", "shooters_per_salvo" })
        ),
        firing_range = doctrine_wra_value(
            safe_get(value, { "firing_range", "FiringRange" })
        ),
        self_defence_range = doctrine_wra_value(
            safe_get(
                value,
                { "self_defence", "SelfDefence", "self_defence_range" }
            )
        ),
    })
end

local function doctrine_wra_result(arguments, raw)
    local entries = Json.array()
    local direct = doctrine_wra_entry(raw, nil)
    if direct ~= nil then
        entries[#entries + 1] = direct
    else
        local indexed = {}
        pcall(function()
            for key, value in pairs(raw) do
                local entry = doctrine_wra_entry(value, key)
                if entry ~= nil then
                    indexed[#indexed + 1] = entry
                end
            end
        end)
        table.sort(indexed, function(left, right)
            return left.weapon_dbid < right.weapon_dbid
        end)
        for _, entry in ipairs(indexed) do
            entries[#entries + 1] = entry
        end
    end
    local target_type = safe_get(raw, { "target_type", "TargetType" })
    if target_type == nil or target_type == Json.null then
        target_type = arguments.target_type
    end
    if target_type == nil or target_type == Json.null then
        target_type = Json.null
    else
        local numeric_target_type = nullable_enum_integer(target_type)
        if numeric_target_type ~= Json.null then
            target_type = numeric_target_type
        else
            target_type = nullable_scalar(target_type)
        end
    end
    return Json.object({
        scope = tostring(arguments.scope),
        target_guid = doctrine_wra_target_guid(arguments),
        level = text_or(safe_get(raw, { "level", "Level" }), tostring(arguments.scope)),
        target_type = target_type,
        entries = entries,
    })
end

local function doctrine_wra_read(arguments)
    local selector = doctrine_wra_selector(arguments, false)
    local ok, raw = pcall(ScenEdit_GetDoctrineWRA, selector)
    if not ok then
        error(
            "ScenEdit_GetDoctrineWRA failed: "
                .. text_or(raw, "no WRA table returned")
        )
    end
    if raw == nil then
        raw = {}
    end
    return doctrine_wra_result(arguments, raw)
end

local function doctrine_wra_get_result(arguments)
    return doctrine_wra_read(arguments)
end

local function doctrine_wra_set_result(arguments)
    local selector = doctrine_wra_selector(arguments, true)
    local settings = {
        arguments.weapons_per_salvo,
        arguments.shooters_per_salvo,
        arguments.firing_range,
        arguments.self_defence_range,
    }
    local ok, changed = pcall(ScenEdit_SetDoctrineWRA, selector, settings)
    if not ok or changed == nil or changed == false then
        error("ScenEdit_SetDoctrineWRA failed: " .. text_or(changed, "false"))
    end
    return doctrine_wra_read(arguments)
end

local function emcon_set_result(arguments)
    local scope = tostring(arguments.scope)
    local target_guid = tostring(arguments.target_guid)
    local ok, changed = pcall(
        ScenEdit_SetEMCON,
        string.upper(string.sub(scope, 1, 1)) .. string.sub(scope, 2),
        target_guid,
        tostring(arguments.emcon)
    )
    if not ok or changed == false then
        error("ScenEdit_SetEMCON failed: " .. text_or(changed, "false"))
    end
    local local_doctrine, _ = doctrine_read(arguments, false)
    local _, actual = doctrine_read(arguments, true)
    local local_emcon = safe_get(local_doctrine, { "emcon", "EMCON", "Emcon" })
    local inherit_value = safe_get(local_emcon, { "inherit", "Inherit" })
    if inherit_value == nil then
        inherit_value = safe_get(local_doctrine, { "emcon_inherit", "EMCONInherit" })
    end
    local observed_inherit = Json.null
    if inherit_value ~= nil then
        observed_inherit = boolean_or(inherit_value, false)
    end
    return Json.object({
        scope = scope,
        target_guid = actual.target_guid,
        inherit = observed_inherit,
        radar = actual.radar,
        sonar = actual.sonar,
        oecm = actual.oecm,
    })
end

local function special_action_item(action)
    return Json.object({
        guid = text_or(safe_get(action, { "guid", "Guid", "GUID" }), ""),
        name = text_or(safe_get(action, { "name", "Name" }), ""),
        description = text_or(
            safe_get(action, { "description", "Description" }),
            ""
        ),
        active = boolean_or(
            safe_get(action, { "isActive", "IsActive", "isactive" }),
            false
        ),
        repeatable = boolean_or(
            safe_get(action, { "IsRepeatable", "isRepeatable", "isrepeatable" }),
            false
        ),
    })
end

local function special_action_list_for_selector(side_selector)
    local descriptor = { mode = "list" }
    if side_selector ~= nil and side_selector ~= Json.null then
        descriptor.side = side_selector
    end
    local ok, actions = pcall(
        ScenEdit_GetSpecialAction,
        descriptor
    )
    if not ok or actions == nil then
        error(
            "ScenEdit_GetSpecialAction list failed: "
                .. text_or(actions, "no actions returned")
        )
    end
    return actions
end

local function special_action_list_result(arguments)
    local side_selector = nil
    if (arguments.side_guid ~= nil and arguments.side_guid ~= Json.null)
        or (arguments.side_name ~= nil and arguments.side_name ~= Json.null)
    then
        local side = resolve_side(arguments)
        side_selector = side_api_selector(arguments, side)
    end
    local normalized = {}
    for _, action in ipairs(
        collect_ordered(special_action_list_for_selector(side_selector))
    ) do
        local item = special_action_item(action)
        if item.guid ~= "" then
            normalized[#normalized + 1] = item
        end
    end
    table.sort(normalized, function(left, right)
        return left.guid < right.guid
    end)
    local items = Json.array()
    for _, item in ipairs(normalized) do
        items[#items + 1] = item
    end
    return Json.object({ items = items })
end

local function special_action_read(side_selector, action_guid, side)
    local ok, action = pcall(
        ScenEdit_GetSpecialAction,
        { side = side_selector, ActionNameOrID = action_guid }
    )
    if not ok or action == nil then
        error(
            "ScenEdit_GetSpecialAction failed: "
                .. text_or(action, "action not found")
        )
    end
    local observed_guid = text_or(
        safe_get(action, { "guid", "Guid", "GUID" }),
        ""
    )
    if observed_guid ~= action_guid then
        error("special action GUID did not match requested action")
    end
    local owner = normalized_object_reference(safe_get(action, { "side", "Side" }))
    if owner ~= Json.null then
        local owner_key = lower_text(owner)
        local selector_key = lower_text(side_selector)
        local side_guid_key = lower_text(object_guid(side))
        local side_name_key = lower_text(object_name(side))
        if owner_key ~= selector_key
            and owner_key ~= side_guid_key
            and owner_key ~= side_name_key
        then
            error("special action does not belong to the requested side")
        end
    elseif owner == Json.null then
        local found = false
        for _, candidate in ipairs(
            collect_ordered(special_action_list_for_selector(side_selector))
        ) do
            if object_guid(candidate) == action_guid then
                found = true
                break
            end
        end
        if not found then
            error("special action was not present in the requested side list")
        end
    end
    return action
end

local function special_action_execute_result(arguments)
    local side = resolve_side(arguments)
    local side_selector = side_api_selector(arguments, side)
    local action_guid = tostring(arguments.action_guid)
    special_action_read(side_selector, action_guid, side)
    local ok, execution = pcall(ScenEdit_ExecuteSpecialAction, action_guid)
    if not ok or execution == false then
        error(
            "ScenEdit_ExecuteSpecialAction failed: "
                .. text_or(execution, "false")
        )
    end
    local action = special_action_read(side_selector, action_guid, side)
    local item = special_action_item(action)
    return Json.object({
        action_guid = item.guid,
        name = item.name,
        accepted = true,
        active = item.active,
        repeatable = item.repeatable,
    })
end

