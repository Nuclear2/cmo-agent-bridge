local function unit_loadout_set_result(arguments)
    local unit_guid = tostring(arguments.unit_guid)
    local requested_loadout = integer_or(arguments.loadout_dbid, 0)
    local descriptor = {
        unitname = unit_guid,
        LoadoutID = requested_loadout,
    }
    if arguments.time_to_ready_minutes ~= nil
        and arguments.time_to_ready_minutes ~= Json.null
    then
        descriptor.TimeToReady_Minutes = number_or(arguments.time_to_ready_minutes, 0)
    end
    if arguments.ignore_magazines ~= nil and arguments.ignore_magazines ~= Json.null then
        descriptor.IgnoreMagazines = arguments.ignore_magazines == true
    end
    if arguments.exclude_optional_weapons ~= nil
        and arguments.exclude_optional_weapons ~= Json.null
    then
        descriptor.ExcludeOptionalWeapons = arguments.exclude_optional_weapons == true
    end
    local ok, changed = pcall(ScenEdit_SetLoadout, descriptor)
    if not ok or changed ~= true then
        error("ScenEdit_SetLoadout failed: " .. text_or(changed, "false"))
    end
    local actual = unit_loadout_result(unit_guid)
    if actual.loadout_dbid ~= requested_loadout then
        error("loadout readback did not match the requested DBID")
    end
    return actual
end

